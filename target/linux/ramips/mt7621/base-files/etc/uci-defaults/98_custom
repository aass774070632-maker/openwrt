#!/bin/sh
# Do not re-apply factory defaults after sysupgrade with "keep settings".
if [ -f /sysupgrade.tgz ] || [ -f /tmp/sysupgrade.tar ]; then
    exit 0
fi

board_name="$(ubus call system board 2>/dev/null | jsonfilter -e '@.board_name' 2>/dev/null)"
device_lan_ipaddr='192.168.1.20'
device_hostname='KT-KM12-007H'
device_ssid_2g='KT-KM12-007H-2.4'
device_ssid_5g='KT-KM12-007H-5G'
device_bridge_ports='lan1 lan2 lan3 lan4 wan'

case "$board_name" in
    kt,km14-102h)
        device_hostname='KT-KM14-102H'
        device_ssid_2g='KT-KM14-102H-2.4GHz'
        device_ssid_5g='KT-KM14-102H-5GHz'
        device_bridge_ports='lan wan'
        ;;
    kt,km12-007h|'')
        ;;
esac

##########################
##########################
# /etc/config/dhcp
uci del dhcp.lan.ra
uci del dhcp.lan.ra_slaac
uci del dhcp.lan.ra_flags
uci del dhcp.lan.dhcpv6
uci set dhcp.lan.ignore='1'
uci set dhcp.lan.dynamicdhcp='0'
uci del dhcp.wan
uci set dhcp.odhcpd.maindhcp='0'
##########################
# /etc/config/firewall
uci del firewall.cfg02dc81.network
uci del firewall.cfg03dc81.network
uci add_list firewall.cfg03dc81.network='wan6'
uci del firewall.cfg03dc81.network
uci del firewall.cfg01e63d.syn_flood
uci set firewall.cfg01e63d.input='ACCEPT'
uci set firewall.cfg01e63d.forward='ACCEPT'
uci set firewall.cfg03dc81.input='ACCEPT'
uci set firewall.cfg03dc81.forward='ACCEPT'
##########################
# /etc/config/network
uci del network.lan.ip6assign
uci set network.lan.ipaddr="$device_lan_ipaddr"
uci set network.lan.netmask='255.255.255.0'
uci set network.lan.gateway='192.168.1.2'
uci add_list network.lan.dns='8.8.8.8'
uci add_list network.lan.dns='82.114.163.31'
uci set network.lan.delegate='0'
uci set network.lan.defaultroute='1'
uci del network.wan
uci del network.wan6
uci del network.cfg030f15.ports
for bridge_port in $device_bridge_ports; do
    uci add_list network.cfg030f15.ports="$bridge_port"
done
uci set network.cfg030f15.ageing_time='10'
uci set network.cfg030f15.ipv6='0'
##########################
# /etc/config/wireless
uci set wireless.@wifi-iface[1].ssid="${device_ssid_5g}_$(cat /sys/class/ieee80211/phy1/macaddress|awk -F ":" '{print $5""$6 }'| tr a-z A-Z)"
uci set wireless.@wifi-device[1].disabled='0'
uci set wireless.radio1.channel='36'
uci set wireless.default_radio0.wds='1'
uci set wireless.radio1.htmode='HE80'
uci set wireless.radio1.country='PA'
uci set wireless.@wifi-iface[0].ssid="${device_ssid_2g}_$(cat /sys/class/ieee80211/phy0/macaddress|awk -F ":" '{print $5""$6 }'| tr a-z A-Z)"
uci set wireless.@wifi-device[0].disabled='0'
uci set wireless.radio0.channel='auto'
uci set wireless.default_radio1.wds='1'
uci set wireless.radio0.htmode='HE20'
uci set wireless.radio0.country='PA'
uci set wireless.radio0.cell_density='0'
uci set wireless.default_radio0.disassoc_low_ack='0'
uci set wireless.radio1.cell_density='0'
uci set wireless.default_radio1.disassoc_low_ack='0'
##########################
uci set ttyd.cfg01a8ea.debug='7'
uci set ttyd.cfg01a8ea.command='/usr/libexec/login.sh'
##########################
# /etc/config/lldpd
uci set lldpd.config.enabled='1'
uci set lldpd.config.lldp_hostname="$device_hostname"
uci set lldpd.config.lldp_location='address country YE'
uci set lldpd.config.lldp_platform="$device_hostname"
uci set lldpd.config.lldp_capability_advertisements='1'
uci set lldpd.config.lldp_mgmt_addr_advertisements='1'
uci set lldpd.config.lldp_tx_interval='30'
uci set lldpd.config.lldp_tx_hold='4'
uci set lldpd.config.readonly_mode='0'
uci set lldpd.config.lldp_portidsubtype='macaddress'
uci set lldpd.config.lldp_agenttype='nearest-bridge'
uci set lldpd.config.cdp_version='cdpv1v2'
##########################
uci del system.ntp.enabled
uci del system.ntp.enable_server
uci set system.@system[0].hostname="$device_hostname"
#uci set uhttpd.main.redirect_https='1'
uci -q delete uhttpd.main.listen_https
uci set uhttpd.main.redirect_https='0'
uci set system.cfg01e48a.description='الإمبراطور للبرمجيات'
uci set system.cfg01e48a.notes='تم تعديل هذا السوفت من قبل الإمبراطور للبرمجيات أشراف
