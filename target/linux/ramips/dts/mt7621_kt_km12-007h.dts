#include "mt7621.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
	compatible = "kt,km12-007h", "mediatek,mt7621-soc";
	model = "KT KM12-007H";

	aliases {
		led-boot = &led_wlan;
		led-failsafe = &led_lan2;
		led-running = &led_wlan;
		led-upgrade = &led_lan2;
		label-mac-device = &gmac0;
	};

	chosen {
		bootargs = "console=ttyS0,115200";
	};

	keys {
		compatible = "gpio-keys";

		key-0 {
			label = "wps";
			gpios = <&gpio 4 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_WPS_BUTTON>;
		};

		key-1 {
			label = "reset";
			gpios = <&gpio 3 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
		};
	};

	leds {
		compatible = "gpio-leds";
  
      led_lan2: lan2 {
			label = "green:lan2";
			gpios = <&gpio 14 GPIO_ACTIVE_LOW>;
		};

		led_wlan: wlan {
			label = "green:wlan";
			gpios = <&gpio 13 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "phy0radio";
		};
	};

	reg_usb_vbus: regulator-usb {
		compatible = "regulator-fixed";
		regulator-name = "usb_vbus";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		gpios = <&gpio 15 GPIO_ACTIVE_HIGH>;
		enable-active-high;
	};

	reg_3p3v: regulator-3p3v {
		compatible = "regulator-fixed";
		regulator-name = "fixed-3.3V";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-boot-on;
		regulator-always-on;
	};
};

&xhci {
	vusb33-supply = <&reg_3p3v>;
	vbus-supply = <&reg_usb_vbus>;
};

&state_default {
	gpio {
		groups = "i2c", "jtag", "uart3", "wdt";
		function = "gpio";
	};
};

&gmac0 {
	nvmem-cells = <&macaddr_config_60004>;
	nvmem-cell-names = "mac-address";
};

&nand {
	status = "okay";

	mediatek,nmbm;

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		partition@0 {
			label = "Bootloader";
			reg = <0x0 0x80000>;
			read-only;
		};

		partition@80000 {
			label = "Config";
			reg = <0x80000 0x80000>;

			nvmem-layout {
				compatible = "fixed-layout";
				#address-cells = <1>;
				#size-cells = <1>;

				macaddr_config_60004: macaddr@60004 {
					reg = <0x60004 0x6>;
				};
				};
			};

		factory: partition@100000 {
			label = "Factory";
			reg = <0x100000 0x40000>;
		};

		partition@140000 {
				label = "kernel";
			reg = <0x140000 0x400000>;
			};

		partition@540000 {
				label = "ubi";
			reg = <0x540000 0x7A40000>;
		};
	};
};

&pcie {
	status = "okay";
};

&pcie1 {
	wifi@0,0 {
		compatible = "mediatek,mt76";
		reg = <0x0000 0 0 0 0>;
    mediatek,mtd-eeprom = <&factory 0x0>;
		mediatek,disable-radar-background;
	};
};

&switch0 {
	ports {
		port@0 {
			status = "okay";
			label = "wan";
		};

		port@1 {
			status = "okay";
			label = "lan4";
		};

		port@2 {
			status = "okay";
			label = "lan3";
		};

		port@3 {
			status = "okay";
			label = "lan2";
		};

		port@4 {
			status = "okay";
			label = "lan1";
		};
	};
};