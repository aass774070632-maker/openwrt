#!/bin/sh
# Alemprator shared uci-defaults for qualcommax/ipq60xx
# Applies per-board SSID, hostname, bridge ports automatically.
# Supported: AR06-012H, AR07-102H, DV02-012H, LG-GAPD-7500

# Do not re-apply factory defaults after sysupgrade with "keep settings".
if [ -f /sysupgrade.tgz ] || [ -f /tmp/sysupgrade.tar ]; then
    exit 0
fi

# ─── Read board name ────────────────────────────────────────
. /lib/functions.sh
board_name=$(board_name)

# ─── Per-board settings ─────────────────────────────────────
device_hostname=''
device_ssid_prefix=''
device_lldp_name=''
device_bridge_ports='lan1 lan2 lan3 lan4 wan'

case "$board_name" in
    kt,ar06-012h)
        device_hostname='KT-AR06-012H'
        device_ssid_prefix='AR06-012H'
        device_lldp_name='AR06-012H'
        device_bridge_ports='lan1 lan2 lan3 lan4 wan'
        ;;
    kt,ar07-102h)
        device_hostname='KT-AR07-102H'
        device_ssid_prefix='AR07-102H'
        device_lldp_name='AR07-102H'
        device_bridge_ports='lan wan'
        ;;
    kt,dv02-012h)
        device_hostname='KT-DV02-012H'
        device_ssid_prefix='DV02-012H'
        device_lldp_name='DV02-012H'
        device_bridge_ports='lan1 lan2 lan3 lan4 wan'
        ;;
    lg,gapd-7500)
        device_hostname='LG-GAPD-7500'
        device_ssid_prefix='LG-GAPD-7500'
        device_lldp_name='LG-GAPD-7500'
        device_bridge_ports='lan2 lan3 lan4 wan'
        ;;
    *)
        # Unknown board — use generic defaults
        device_hostname='ALemprator-Router'
        device_ssid_prefix='ALemprator'
        device_lldp_name='ALemprator'
        ;;
esac

# ─── DHCP (disable — bridge/AP mode) ────────────────────────
uci del dhcp.lan.ra 2>/dev/null
uci del dhcp.lan.ra_slaac 2>/dev/null
uci del dhcp.lan.ra_flags 2>/dev/null
uci del dhcp.lan.dhcpv6 2>/dev/null
uci set dhcp.lan.ignore='1'
uci set dhcp.lan.dynamicdhcp='0'
uci del dhcp.wan 2>/dev/null
uci set dhcp.odhcpd.maindhcp='0'

# ─── Firewall (open for bridge mode) ────────────────────────
uci del firewall.cfg02dc81.network 2>/dev/null
uci del firewall.cfg03dc81.network 2>/dev/null
uci add_list firewall.cfg03dc81.network='wan6' 2>/dev/null
uci del firewall.cfg03dc81.network 2>/dev/null
uci del firewall.cfg01e63d.syn_flood 2>/dev/null
uci set firewall.cfg01e63d.input='ACCEPT'
uci set firewall.cfg01e63d.forward='ACCEPT'
uci set firewall.cfg03dc81.input='ACCEPT'
uci set firewall.cfg03dc81.forward='ACCEPT'

# ─── Network (LAN bridge + AP mode) ─────────────────────────
uci del network.lan.ip6assign 2>/dev/null
uci set network.lan.ipaddr='192.168.1.20'
uci set network.lan.netmask='255.255.255.0'
uci add_list network.lan.dns='8.8.8.8'
uci add_list network.lan.dns='1.1.1.1'
uci add_list network.lan.dns='82.114.163.31'
uci set network.lan.gateway='192.168.1.2'
uci set network.lan.delegate='0'
uci set network.lan.defaultroute='1'
uci del network.wan 2>/dev/null
uci del network.wan6 2>/dev/null

# Direct DNS for the router itself (dnsmasq is disabled in bridge mode)
cat > /etc/resolv.conf <<'RESOLVEOF'
nameserver 8.8.8.8
nameserver 1.1.1.1
nameserver 82.114.163.31
RESOLVEOF

# Bridge ports (per-board)
uci del network.cfg030f15.ports 2>/dev/null
for port in $device_bridge_ports; do
    uci add_list network.cfg030f15.ports="$port"
done
uci set network.cfg030f15.ageing_time='10'
uci set network.cfg030f15.ipv6='0'

# ─── Wireless (per-board SSID with MAC suffix) ──────────────
mac_suffix_2g=$(cat /sys/class/ieee80211/phy1/macaddress 2>/dev/null | awk -F ":" '{print $5""$6}' | tr a-z A-Z)
mac_suffix_5g=$(cat /sys/class/ieee80211/phy0/macaddress 2>/dev/null | awk -F ":" '{print $5""$6}' | tr a-z A-Z)

# 2.4GHz radio (phy1)
uci set wireless.@wifi-iface[1].ssid="${device_ssid_prefix}-2.4_${mac_suffix_2g}"
uci set wireless.@wifi-device[1].disabled='0'
uci set wireless.radio1.channel='auto'
uci set wireless.default_radio1.wds='1'
uci set wireless.radio1.htmode='HE20'
uci set wireless.radio1.country='PA'
uci set wireless.radio1.cell_density='0'
uci set wireless.radio1.txpower='36'
uci set wireless.default_radio1.disassoc_low_ack='0'

# 5GHz radio (phy0)
uci set wireless.@wifi-iface[0].ssid="${device_ssid_prefix}-5G_${mac_suffix_5g}"
uci set wireless.@wifi-device[0].disabled='0'
uci set wireless.radio0.channel='auto'
uci set wireless.default_radio0.wds='1'
uci set wireless.radio0.htmode='HE80'
uci set wireless.radio0.country='PA'
uci set wireless.radio0.cell_density='0'
uci set wireless.radio0.txpower='36'
uci set wireless.default_radio0.disassoc_low_ack='0'

# ─── TTYD ───────────────────────────────────────────────────
uci set ttyd.cfg01a8ea.debug='7'
uci set ttyd.cfg01a8ea.command='/usr/libexec/login.sh'

# ─── LLDP (per-board) ───────────────────────────────────────
uci set lldpd.config.enabled='1'
uci set lldpd.config.lldp_hostname="$device_lldp_name"
uci set lldpd.config.lldp_location='address country YE'
uci set lldpd.config.lldp_platform="$device_lldp_name"
uci set lldpd.config.lldp_capability_advertisements='1'
uci set lldpd.config.lldp_mgmt_addr_advertisements='1'
uci set lldpd.config.lldp_tx_interval='30'
uci set lldpd.config.lldp_tx_hold='4'
uci set lldpd.config.readonly_mode='0'
uci set lldpd.config.lldp_portidsubtype='macaddress'
uci set lldpd.config.lldp_agenttype='nearest-bridge'
uci set lldpd.config.cdp_version='cdpv1v2'

# ─── System (per-board hostname) ────────────────────────────
uci del system.ntp.enabled 2>/dev/null
uci del system.ntp.enable_server 2>/dev/null
uci set system.@system[0].hostname="$device_hostname"
uci -q delete uhttpd.main.listen_https
uci set uhttpd.main.redirect_https='0'
uci set system.cfg01e48a.description='الإمبراطور للبرمجيات'
uci set system.cfg01e48a.notes='تم تعديل هذا السوفت من قبل الإمبراطور للبرمجيات أشراف
م/محمد باعلوي
+967777440819
م/جلال القحم
+967774070632
https://facebook.com/baalwiy
https://youtube.com/c/MOHAMMEDABAALAWI
http://t.me/b777440819
https://facebook.com/baalwiy
https://api.whatsapp.com/send/?phone=967777440819'
uci set system.cfg01e48a.zonename='Asia/Aden'
uci set system.cfg01e48a.timezone='<+03>-3'
uci set system.cfg01e48a.log_proto='udp'
uci set system.cfg01e48a.conloglevel='8'
uci set system.cfg01e48a.cronloglevel='5'
uci del watchcat.cfg01e014 2>/dev/null

# ─── Commit all ─────────────────────────────────────────────
uci commit lldpd
uci commit network
uci commit firewall
uci commit dhcp
uci commit system
uci commit wireless
uci commit

# ─── Disable unused services for bridge/AP mode ─────────────
RC_LOCAL="/etc/rc.local"
RC_LOCAL_TMP="/tmp/rc.local.$$"
RC_LOCAL_MARKER="# Added by 98_custom: disable unused bridge-mode services"

[ -f "$RC_LOCAL" ] || {
    echo '# Put your custom commands here that should be executed once'
    echo '# the system init finished. By default this file does nothing.'
    echo
    echo 'exit 0'
} > "$RC_LOCAL"

if ! grep -q "$RC_LOCAL_MARKER" "$RC_LOCAL" 2>/dev/null; then
    sed '/^exit 0$/d' "$RC_LOCAL" > "$RC_LOCAL_TMP"
    cat >> "$RC_LOCAL_TMP" <<'EOF'

# Added by 98_custom: disable unused bridge-mode services
/etc/init.d/firewall disable
/etc/init.d/log disable
/etc/init.d/urandom_seed disable
/etc/init.d/odhcpd disable
/etc/init.d/dnsmasq disable
exit 0
EOF
    cat "$RC_LOCAL_TMP" > "$RC_LOCAL"
    rm -f "$RC_LOCAL_TMP"
fi

sync

exit 0
