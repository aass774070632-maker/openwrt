#!/bin/sh
# logs — Return recent Hotspot/Chilli/RADIUS log lines as JSON
# Usage: logs [lines]

LINES="${1:-100}"
LINES="$(printf '%s' "$LINES" | awk '{ v=$1+0; if(v<1)v=1; if(v>500)v=500; print v }')"

json_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/ /g'
}

entries=''
count=0

while IFS= read -r line; do
	escaped="$(json_escape "$line")"
	[ -z "$escaped" ] && continue
	if [ -n "$entries" ]; then
		entries="$entries,"
	fi
	entries="${entries}\"$escaped\""
	count=$((count + 1))
done <<EOF
$(logread 2>/dev/null | grep -E -i 'chilli|coova|radius|hotspot|tun0|uam' | tail -n "$LINES")
EOF

printf '{"ok":true,"count":%d,"lines":[%s]}\n' "$count" "$entries"
