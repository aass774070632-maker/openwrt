#!/bin/sh
# gen-ssl — Generate a self-signed TLS certificate for UAM SSL (port 3991)
# Usage: gen-ssl [cert_path] [key_path] [cn]
# Defaults: /etc/chilli/hotspot.crt  /etc/chilli/hotspot.key  hotspot.local

CERT="${1:-/etc/chilli/hotspot.crt}"
KEY="${2:-/etc/chilli/hotspot.key}"
RAW_CN="${3:-$(uci -q get hotspot_openwrt.main.domain || echo hotspot.local)}"
HOTSPOT_IP="$(uci -q get hotspot_openwrt.main.hotspot_ip || echo 192.168.10.1)"

# Sanitize CN: allow only hostname-safe characters (alphanumeric, dots, hyphens)
CN="$(printf '%s' "$RAW_CN" | tr -cd 'a-zA-Z0-9.-' | cut -c1-64)"
[ -n "$CN" ] || CN="hotspot.local"

# Sanitize HOTSPOT_IP: allow only digits and dots, validate proper IPv4 format
HOTSPOT_IP="$(printf '%s' "$HOTSPOT_IP" | tr -cd '0-9.' | grep -E '^[0-9]{1,3}(\.[0-9]{1,3}){3}$' || echo '')"
[ -n "$HOTSPOT_IP" ] || HOTSPOT_IP="192.168.10.1"

if ! command -v openssl >/dev/null 2>&1; then
	printf '{"ok":false,"message":"openssl غير متوفر على الراوتر. ثبّت باقة openssl أولاً."}\n'
	exit 1
fi

mkdir -p "$(dirname "$CERT")" "$(dirname "$KEY")"

# Generate key + self-signed cert valid for 10 years
openssl req -x509 -newkey rsa:2048 -keyout "$KEY" -out "$CERT" -days 3650 -nodes \
	-subj "/CN=$CN/O=Hotspot OpenWrt/C=YE" \
	-addext "subjectAltName=IP:$HOTSPOT_IP,DNS:$CN" 2>/dev/null

if [ $? -eq 0 ]; then
	chmod 600 "$KEY" 2>/dev/null || true
	chmod 644 "$CERT" 2>/dev/null || true
	printf '{"ok":true,"cert":"%s","key":"%s","cn":"%s","message":"تم توليد شهادة SSL ذاتية التوقيع بنجاح."}\n' "$CERT" "$KEY" "$CN"
else
	printf '{"ok":false,"message":"فشل توليد شهادة SSL. تحقق من وجود openssl وتوفر مساحة كافية."}\n'
	exit 1
fi
