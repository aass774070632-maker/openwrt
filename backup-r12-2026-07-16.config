package system

config system
	option hostname 'KT-KM14-102H'
	option timezone '<+03>-3'
	option ttylogin '0'
	option log_size '128'
	option urandom_seed '0'
	option compat_version '1.1'
	option description 'الإمبراطور للبرمجيات'
	option notes 'تم تعديل هذا السوفت من قبل الإمبراطور للبرمجيات أشراف
م/محمد باعلوي
+967777440819
م/جلال القحم
+967774070632
https://facebook.com/baalwiy
https://youtube.com/c/MOHAMMEDABAALAWI
http://t.me/b777440819
https://facebook.com/baalwiy
https://api.whatsapp.com/send/?phone=967777440819'
	option zonename 'Asia/Aden'
	option log_proto 'udp'
	option conloglevel '8'
	option cronloglevel '5'

config timeserver 'ntp'
	list server '0.openwrt.pool.ntp.org'
	list server '1.openwrt.pool.ntp.org'
	list server '2.openwrt.pool.ntp.org'
	list server '3.openwrt.pool.ntp.org'

config led 'led_lan'
	option name 'LAN'
	option sysfs 'green:lan'
	option trigger 'netdev'
	option mode 'link tx rx'
	option dev 'lan'

config led 'led_wan'
	option name 'WAN'
	option sysfs 'green:wan'
	option trigger 'netdev'
	option mode 'link tx rx'
	option dev 'wan'

config led 'led_wlan'
	option name 'WiFi 5GHz'
	option sysfs 'mt76-phy0'
	option trigger 'netdev'
	option mode 'link tx rx'
	option dev 'phy1-ap0'

config 0 'autoreboot'

package ttyd

config ttyd
	option interface '@lan'
	option command '/usr/libexec/login.sh'
	option debug '7'

package ubihealthd

config ubi-device 'ubi0'
	option device '/dev/ubi0'
	option enable '1'

package uhttpd

config uhttpd 'main'
	list listen_http '0.0.0.0:80'
	list listen_http '[::]:80'
	option redirect_https '0'
	option home '/www'
	option rfc1918_filter '1'
	option max_requests '3'
	option max_connections '100'
	option cert '/etc/uhttpd.crt'
	option key '/etc/uhttpd.key'
	option cgi_prefix '/cgi-bin'
	list lua_prefix '/cgi-bin/luci=/usr/lib/lua/luci/sgi/uhttpd.lua'
	option script_timeout '60'
	option network_timeout '30'
	option http_keepalive '20'
	option tcp_keepalive '1'
	option ubus_prefix '/ubus'
	option error_page '/cgi-bin/generate_204'

config cert 'defaults'
	option days '397'
	option key_type 'ec'
	option bits '2048'
	option ec_curve 'P-256'
	option country 'ZZ'
	option state 'Somewhere'
	option location 'Unknown'
	option commonname 'OpenWrt'

package watchcat

package wireless

config wifi-device 'radio0'
	option type 'mac80211'
	option path '1e140000.pcie/pci0000:00/0000:00:01.0/0000:02:00.0'
	option band '2g'
	option channel 'auto'
	option htmode 'HE20'
	option disabled '0'
	option country 'PA'
	option cell_density '0'
	option txpower '36'
	option hwmode '11g'

config wifi-device 'radio1'
	option type 'mac80211'
	option path '1e140000.pcie/pci0000:00/0000:00:01.0/0000:02:00.0+1'
	option band '5g'
	option channel '36'
	option htmode 'HE80'
	option disabled '0'
	option country 'PA'
	option cell_density '0'
	option txpower '36'
	option hwmode '11a'

config wifi-iface 'wizard_hotspot_quick_primary'
	option device 'radio0'
	option mode 'ap'
	option network 'hotspot'
	option disabled '0'
	option ssid 'Hotspot-1'
	option hidden '0'
	option isolate '1'
	option disassoc_low_ack '0'
	option encryption 'none'

config wifi-iface 'wizard_hotspot_quick_secondary'
	option device 'radio1'
	option mode 'ap'
	option network 'hotspot2'
	option disabled '0'
	option ssid 'Hotspot-2'
	option hidden '0'
	option isolate '1'
	option disassoc_low_ack '0'
	option encryption 'none'

