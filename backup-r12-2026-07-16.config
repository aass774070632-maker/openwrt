package alemprator-network-protection

config globals 'main'
	option enabled '1'
	option debug '0'
	option log_level 'info'
	option monitor_interval '5'
	option auto_recover '1'
	option recovery_delay '60'
	option max_actions_per_minute '10'
	option bridges 'br-lan'

config loop_protection 'loop'
	option enabled '1'
	option action 'warn'
	option max_mac_moves '5'
	option window_seconds '10'
	option auto_recover '1'
	option recovery_delay '60'
	option notify '1'

config broadcast_storm 'broadcast'
	option enabled '1'
	option action 'rate_limit'
	option max_pps '500'
	option max_ratio '30'
	option window_seconds '5'
	option storm_duration_seconds '3'
	option rate_limit_kbps '1000'
	option auto_recover '1'
	option recovery_delay '30'
	option notify '1'

config arp_storm 'arp'
	option enabled '1'
	option action 'warn'
	option max_arp_pps '100'
	option window_seconds '5'
	option storm_duration_seconds '3'
	option rate_limit_kbps '500'
	option auto_recover '1'
	option recovery_delay '30'
	option notify '1'
	option exclude_gateway '1'

config dhcp_rogue 'dhcp_rogue'
	option enabled '1'
	option action 'warn'
	option auto_block '0'
	option notify '1'

config mac_flapping 'mac_flapping'
	option enabled '1'
	option action 'warn'
	option max_flaps '10'
	option window_seconds '30'
	option auto_recover '1'
	option recovery_delay '120'
	option notify '1'

config port_isolation 'port_isolation'
	option enabled '0'
	option default_action 'isolate'
	option quarantine_bridge 'br-lan'
	option guest_vlan '100'
	option notify '1'

config rstp 'rstp'
	option enabled '0'
	option bridge_priority '32768'
	option forward_delay '15'
	option hello_time '2'
	option max_age '20'
	option notify '1'

config trusted_dhcp 'trusted_dhcp'
	option mac '00:11:22:33:44:55'
	option comment 'Primary router'

config trusted_dhcp 'trusted_dhcp_2'
	option mac 'AA:BB:CC:DD:EE:FF'
	option comment 'Backup DHCP server'

package alemprator_firstboot

config firstboot 'main'
	option enabled '0'
	option configured_once '1'
	option auto_cleanup_armed '0'
	option auto_cleanup_delay '15'
	option auto_cleanup_pending '0'
	option configured_flag '/etc/configured'
	option pending_flag '/etc/alemprator-firstboot-pending'
	option lan_ipaddr '192.168.1.20'
	option lan_netmask '255.255.255.0'
	option setup_ipaddr '192.168.8.1'
	option setup_netmask '255.255.255.0'
	option start '100'
	option limit '50'
	option leasetime '1h'
	option network_section 'alemprator_setup'
	option dhcp_section 'alemprator_setup'
	option wireless_section 'alemprator_firstboot'
	option firewall_section 'alemprator_setup'
	option radio 'radio0'
	option ssid 'ALemprator-KT-KM14-102H'
	option encryption 'none'

package alemprator_ota

config ota 'main'
	option enabled '1'
	option server_url 'https://ota.kartnet.org'
	option register_path '/api/register'
	option update_path '/api/update'
	option heartbeat_path '/api/heartbeat'
	option check_interval '21600'
	option random_delay_max '3600'
	option auto_upgrade '1'
	option require_setup_complete '0'
	option keep_config '1'
	option allow_force '1'
	option window_start '2'
	option window_end '6'
	option retry_base '900'
	option retry_max '21600'
	option token_salt 'CHANGE_ME_UNIQUE_PER_BRAND'
	option connect_timeout '20'
	option model_file '/etc/model'
	option model_identity_file '/etc/alemprator/model-identities'
	option token_file '/etc/alemprator/device.token'
	option version_file '/etc/alemprator/firmware-version'
	option state_file '/tmp/alemprator-ota/state.env'

package bandix-plus

config bandix_plus 'general'
	option enable_traffic '1'
	list iface 'br-lan'
	option log_level 'info'
	option tc_order 'first'
	option port '8787'
	option data_dir '/usr/share/bandix-plus'

package chilli

config chilli
	option disabled '1'
	option tundev 'tun0'
	option ipup '/etc/chilli/up.sh'
	option ipdown '/etc/chilli/down.sh'
	option radiusserver1 'rad01.chillispot.org'
	option radiusserver2 'rad02.chillispot.org'
	option dhcpif 'eth1'
	option uamserver 'https://radius.chillispot.org/hotspotlogin'

config chilli 'hotspot_openwrt'
	option disabled '0'
	option tundev 'tun0'
	option ipup '/etc/chilli/up.sh'
	option ipdown '/etc/chilli/down.sh'
	option conup '/etc/chilli/conup.sh'
	option condown '/etc/chilli/condown.sh'
	option network 'hotspot'
	option net '192.168.10.0/24'
	option dynip '192.168.10.0/24'
	option dhcpstart '10'
	option dhcpend '199'
	option uamlisten '192.168.10.1'
	option uamport '3990'
	option nochallenge '1'
	option uamserver 'http://192.168.10.1/hotspot/login.html'
	option uamhomepage 'http://192.168.10.1/hotspot/login.html'
	option radiusserver1 '127.0.0.1'
	option radiusserver2 '127.0.0.1'
	option radiussecret '12345678'
	option radiusauthport '1812'
	option radiusacctport '1813'
	option nasip '192.168.1.20'
	option radiusnasid 'KT-KM14-102H-HOTSPOT'
	option acctupdate '1'
	option domain 'b.net'
	option dns1 '192.168.10.1'
	option dns2 '192.168.10.1'
	option forcedns1 '127.0.0.1'
	option forcedns1port '53'
	option forcedns2 '127.0.0.1'
	option forcedns2port '53'
	option uamanydns '1'
	option uamdomainttl '5'
	option mtu '1400'
	option sndbuf '65536'
	option rcvbuf '65536'
	option uamallowed '192.168.10.1,192.168.10.1:80,192.168.10.1:3990,192.168.10.1:3991,b.net,b.net:80'
	option redir '1'
	option redirurl '1'
	option definteriminterval '60'
	option defbandwidthmaxup '2000000'
	option defbandwidthmaxdown '1000000'

config chilli 'hotspot_openwrt_secondary'
	option disabled '0'
	option tundev 'tun1'
	option ipup '/etc/chilli/up.sh'
	option ipdown '/etc/chilli/down.sh'
	option conup '/etc/chilli/conup.sh'
	option condown '/etc/chilli/condown.sh'
	option network 'hotspot2'
	option net '192.168.20.0/24'
	option dynip '192.168.20.0/24'
	option dhcpstart '10'
	option dhcpend '199'
	option uamlisten '192.168.20.1'
	option uamport '3991'
	option nochallenge '1'
	option redir '1'
	option redirurl '1'
	option uamserver 'http://192.168.20.1/hotspot/login.html'
	option uamhomepage 'http://192.168.20.1/hotspot/login.html'
	option radiusserver1 '127.0.0.1'
	option radiusserver2 '127.0.0.1'
	option radiussecret '12345678'
	option radiusauthport '1812'
	option radiusacctport '1813'
	option nasip '192.168.1.20'
	option radiusnasid 'KT-KM14-102H-HOTSPOT'
	option acctupdate '1'
	option domain 'b.net'
	option dns1 '192.168.20.1'
	option dns2 '192.168.20.1'
	option forcedns1 '127.0.0.1'
	option forcedns1port '53'
	option forcedns2 '127.0.0.1'
	option forcedns2port '53'
	option uamanydns '1'
	option uamdomainttl '5'
	option mtu '1400'
	option sndbuf '65536'
	option rcvbuf '65536'
	option uamallowed '192.168.20.1,192.168.20.1:80,192.168.20.1:3990,192.168.20.1:3991,b.net,b.net:80'
	option definteriminterval '60'
	option defbandwidthmaxup '15000000'
	option defbandwidthmaxdown '30000000'

package cpu-perf

config main 'config'
	option enabled '1'

config kernel 'eas'

config module 'pcie_aspm'

config governor 'ondemand'

config governor 'conservative'

package dhcp

config dnsmasq
	option domainneeded '1'
	option boguspriv '1'
	option filterwin2k '0'
	option localise_queries '1'
	option rebind_protection '1'
	option rebind_localhost '1'
	option local '/lan/'
	option domain 'lan'
	option expandhosts '1'
	option nonegcache '0'
	option cachesize '1000'
	option authoritative '1'
	option readethers '1'
	option leasefile '/tmp/dhcp.leases'
	option resolvfile '/tmp/resolv.conf.d/resolv.conf.auto'
	option nonwildcard '0'
	option localservice '0'
	option ednspacket_max '1232'
	option filter_aaaa '1'
	option filter_a '0'
	list server '8.8.8.8'
	list server '1.1.1.1'

config dhcp 'lan'
	option interface 'lan'
	option start '100'
	option limit '150'
	option leasetime '12h'
	option dhcpv4 'server'
	option ignore '1'
	option dynamicdhcp '0'

config odhcpd 'odhcpd'
	option maindhcp '0'
	option leasefile '/tmp/hosts/odhcpd'
	option leasetrigger '/usr/sbin/odhcpd-update'
	option loglevel '4'
	option piofolder '/tmp/odhcpd-piofolder'

config dhcp 'hotspot'
	option interface 'hotspot'
	option ignore '1'

config dhcp 'hotspot2'
	option interface 'hotspot2'
	option ignore '1'

package dropbear

config dropbear 'main'
	option enable '1'
	option PasswordAuth 'on'
	option RootPasswordAuth 'on'
	option Port '22'

package firewall

config defaults
	option input 'ACCEPT'
	option output 'ACCEPT'
	option forward 'ACCEPT'

config zone
	option name 'lan'
	option input 'ACCEPT'
	option output 'ACCEPT'
	option forward 'ACCEPT'
	option masq '1'
	option mtu_fix '1'

config zone
	option name 'wan'
	option input 'ACCEPT'
	option output 'ACCEPT'
	option forward 'ACCEPT'
	option masq '1'
	option mtu_fix '1'

config forwarding
	option src 'lan'
	option dest 'wan'

config rule
	option name 'Allow-DHCP-Renew'
	option src 'wan'
	option proto 'udp'
	option dest_port '68'
	option target 'ACCEPT'
	option family 'ipv4'

config rule
	option name 'Allow-Ping'
	option src 'wan'
	option proto 'icmp'
	option icmp_type 'echo-request'
	option family 'ipv4'
	option target 'ACCEPT'

config rule
	option name 'Allow-IGMP'
	option src 'wan'
	option proto 'igmp'
	option family 'ipv4'
	option target 'ACCEPT'

config rule
	option name 'Allow-DHCPv6'
	option src 'wan'
	option proto 'udp'
	option dest_port '546'
	option family 'ipv6'
	option target 'ACCEPT'

config rule
	option name 'Allow-MLD'
	option src 'wan'
	option proto 'icmp'
	option src_ip 'fe80::/10'
	list icmp_type '130/0'
	list icmp_type '131/0'
	list icmp_type '132/0'
	list icmp_type '143/0'
	option family 'ipv6'
	option target 'ACCEPT'

config rule
	option name 'Allow-ICMPv6-Input'
	option src 'wan'
	option proto 'icmp'
	list icmp_type 'echo-request'
	list icmp_type 'echo-reply'
	list icmp_type 'destination-unreachable'
	list icmp_type 'packet-too-big'
	list icmp_type 'time-exceeded'
	list icmp_type 'bad-header'
	list icmp_type 'unknown-header-type'
	list icmp_type 'router-solicitation'
	list icmp_type 'neighbour-solicitation'
	list icmp_type 'router-advertisement'
	list icmp_type 'neighbour-advertisement'
	option limit '1000/sec'
	option family 'ipv6'
	option target 'ACCEPT'

config rule
	option name 'Allow-ICMPv6-Forward'
	option src 'wan'
	option dest '*'
	option proto 'icmp'
	list icmp_type 'echo-request'
	list icmp_type 'echo-reply'
	list icmp_type 'destination-unreachable'
	list icmp_type 'packet-too-big'
	list icmp_type 'time-exceeded'
	list icmp_type 'bad-header'
	list icmp_type 'unknown-header-type'
	option limit '1000/sec'
	option family 'ipv6'
	option target 'ACCEPT'

config rule
	option name 'Allow-IPSec-ESP'
	option src 'wan'
	option dest 'lan'
	option proto 'esp'
	option target 'ACCEPT'

config rule
	option name 'Allow-ISAKMP'
	option src 'wan'
	option dest 'lan'
	option dest_port '500'
	option proto 'udp'
	option target 'ACCEPT'

config include
	option enabled '1'
	option path '/etc/hotspot-openwrt/firewall.sh'

config zone 'hotspot_openwrt_zone'
	option name 'hotspot'
	option input 'ACCEPT'
	option output 'ACCEPT'
	option forward 'REJECT'
	list network 'hotspot'
	list network 'hotspot2'

config rule 'hotspot_dns'
	option name 'Allow-Hotspot-DNS'
	option src 'hotspot'
	option dest_port '53'
	option proto 'tcp udp'
	option target 'ACCEPT'

config rule 'hotspot_dhcp'
	option name 'Allow-Hotspot-DHCP'
	option src 'hotspot'
	option dest_port '67'
	option proto 'udp'
	option target 'ACCEPT'

config rule 'hotspot_web'
	option name 'Allow-Hotspot-Web'
	option src 'hotspot'
	option dest_port '80 443'
	option proto 'tcp'
	option target 'ACCEPT'

config rule 'hotspot_uam'
	option name 'Allow-Hotspot-UAM'
	option src 'hotspot'
	option dest_port '3990 3991'
	option proto 'tcp'
	option target 'ACCEPT'

package hotspot_openwrt

config hotspot 'main'
	option enabled '1'
	option wan_interface 'wan'
	option subscriber_interface 'hotspot'
	option bridge_ageing_time '10'
	option hotspot_ip '192.168.10.1'
	option hotspot_cidr '24'
	option pool_start '192.168.10.10'
	option pool_end '192.168.10.254'
	option dns1 '8.8.8.8'
	option dns2 '82.114.163.31'
	option domain 'b.net'
	option mtu '1400'
	option txqueuelen '1000'
	option sndbuf '65536'
	option rcvbuf '65536'
	option session_timeout 'none'
	option idle_timeout 'none'
	option keepalive_timeout '00:05:00'
	option status_autorefresh '00:01:00'
	option shared_users '3'
	option open_status_page 'always'
	option radius_server '192.168.1.2'
	option radius_auth_port '1812'
	option radius_acct_port '1813'
	option radius_nas_ip '192.168.1.20'
	option radius_nas_id 'KT-KM14-102H-HOTSPOT'
	option acct_interim '60'
	option coa_enabled '0'
	option coa_port '3799'
	option trial_enabled '0'
	option trial_duration '30'
	option trial_uptime_limit '30'
	option mac_auth_enabled '0'
	option mac_auth_suffix '@mac'
	option userman_rest_enabled '0'
	option userman_rest_scheme 'https'
	option userman_rest_host '192.168.1.2'
	option userman_rest_port '443'
	option userman_rest_insecure_ssl '0'
	option uamssl_enabled '0'
	option uamssl_cert '/etc/chilli/hotspot.crt'
	option uamssl_key '/etc/chilli/hotspot.key'
	option terms_enabled '0'
	option portal_path '/hotspot'
	option portal_storage_path '/www/hotspot'
	option mikrotik_compat '0'
	option network_name 'Hotspot OpenWrt'
	option live_stream_enabled '0'
	option rest_area_enabled '0'
	option login_mode 'both'
	option speedtest_enabled '0'
	option speedtest_url 'https://speed.cloudflare.com/__down?bytes=1048576'
	option quick_setup_enabled '1'
	option quick_wan_interface 'lan'
	option quick_subscriber_interface 'hotspot'
	option quick_subscriber_interface_secondary 'hotspot2'
	option quick_runtime_dual_enabled '1'
	option quick_ssid_primary 'Hotspot-1'
	option quick_gateway_primary '192.168.10.1'
	option quick_pool_start_primary '192.168.10.10'
	option quick_pool_end_primary '192.168.10.199'
	option quick_policy_primary 'standard'
	option quick_ssid_secondary 'Hotspot-2'
	option quick_gateway_secondary '192.168.20.1'
	option quick_pool_start_secondary '192.168.20.10'
	option quick_pool_end_secondary '192.168.20.199'
	option quick_policy_secondary 'premium'
	option captive_notify '0'
	option mac_cookie_enabled '0'
	option browser_cookie_enabled '1'
	option browser_cookie_days '7'
	option radius_secret '12345678'
	option wifi_iface 'wizard_hotspot_quick_primary'
	option rate_limit_rx_tx '1M/2M'
	option maint_enabled '1'
	option maint_start '02:00'
	option maint_end '02:00'
	option maint_mode 'free'
	option available_speeds '3M/4M
5M/6M
7M/8M'
	option debug '1'
	option syslog '1'
	list dns '8.8.8.8'
	list dns '82.114.163.31'

package librespeed-go

config librespeed-go 'config'
	option enabled '0'
	option listen_port '8989'
	option proxyprotocol_port '0'
	option server_lat '0'
	option server_lng '0'
	option redact_ip_addresses '0'
	option database_type 'none'
	option enable_tls '0'
	option enable_http2 '0'

package lldpd

config lldpd 'config'
	option enable_cdp '1'
	option enable_fdp '1'
	option enable_sonmp '1'
	option enable_edp '1'
	option lldp_class '4'
	option lldp_location 'address country YE'
	list interface 'loopback'
	list interface 'lan'
	option enabled '1'
	option lldp_hostname 'KT-KM14-102H'
	option lldp_platform 'KT-KM14-102H'
	option lldp_capability_advertisements '1'
	option lldp_mgmt_addr_advertisements '1'
	option lldp_tx_interval '30'
	option lldp_tx_hold '4'
	option readonly_mode '0'
	option lldp_portidsubtype 'macaddress'
	option lldp_agenttype 'nearest-bridge'
	option cdp_version 'cdpv1v2'

package luci

config core 'main'
	option lang 'auto'
	option mediaurlbase '/luci-static/bootstrap'
	option resourcebase '/luci-static/resources'
	option ubuspath '/ubus/'

config extern 'flash_keep'
	option uci '/etc/config/'
	option dropbear '/etc/dropbear/'
	option openvpn '/etc/openvpn/'
	option passwd '/etc/passwd'
	option opkg '/etc/opkg.conf'
	option firewall '/etc/firewall.user'
	option uploads '/lib/uci/upload/'

config internal 'languages'

config internal 'sauth'
	option sessionpath '/tmp/luci-sessions'
	option sessiontime '3600'

config internal 'ccache'
	option enable '1'

config internal 'themes'
	option Bootstrap '/luci-static/bootstrap'
	option BootstrapDark '/luci-static/bootstrap-dark'
	option BootstrapLight '/luci-static/bootstrap-light'

config internal 'apply'
	option rollback '90'
	option holdoff '4'
	option timeout '5'
	option display '1.5'

config internal 'diag'
	option dns 'openwrt.org'
	option ping 'openwrt.org'
	option route 'openwrt.org'

package luci_netports

config global 'global'
	option default_additional_info '0'
	option default_h_mode '1'
	option hv_mode_switch_button '1'

config port
	option ifname 'lo'
	option disable '1'

config port
	option ifname 'lan1'

config port
	option ifname 'lan2'

config port
	option ifname 'lan3'

config port
	option ifname 'lan4'

config port
	option ifname 'wan'

config port
	option ifname 'br-lan'

package netspeedtest

config netspeedtest 'config'
	option iperf3_enabled '0'
	option librespeed_enabled '0'
	option iperf3_client_port '5201'
	option iperf3_client_protocol 'tcp'
	option iperf3_client_bandwidth '10M'
	option iperf3_client_duration '10'
	option iperf3_client_interval '1'
	option iperf3_client_parallel '1'
	option iperf3_client_reverse '0'
	option mikrotik_btest_port '2000'
	option mikrotik_btest_direction 'receive'
	option mikrotik_btest_duration '8'
	option mikrotik_btest_mtu '1500'
	option openspeedtest_local_port '3000'
	option openspeedtest_server_enabled '0'
	option openspeedtest_server_port '3000'

package network

config interface 'loopback'
	option device 'lo'
	option proto 'static'
	option ipaddr '127.0.0.1'
	option netmask '255.0.0.0'

config globals 'globals'
	option ula_prefix 'fd46:7282:4031::/48'
	option packet_steering '1'

config device
	option name 'br-lan'
	option type 'bridge'
	list ports 'lan1'
	list ports 'lan2'
	list ports 'lan3'
	list ports 'lan4'
	list ports 'wan'
	option ageing_time '10'
	option stp '1'
	option ipv6 '0'

config interface 'lan'
	option device 'br-lan'
	option proto 'static'
	option ipaddr '192.168.1.11'
	option netmask '255.255.255.0'
	list dns '8.8.8.8'
	list dns '1.1.1.1'
	list dns '82.114.163.31'
	option gateway '192.168.1.1'

config device 'hotspot_dev'
	option name 'br-hotspot'
	option type 'bridge'
	option bridge_empty '0'
	option ageing_time '10'
	option ipv6 '0'

config interface 'hotspot'
	option proto 'static'
	option device 'br-hotspot'
	option ipaddr '192.168.10.1'
	option netmask '255.255.255.0'
	option delegate '0'

config device 'hotspot2_dev'
	option name 'br-hotspot2'
	option type 'bridge'
	option bridge_empty '0'
	option ageing_time '10'
	option ipv6 '0'

config interface 'hotspot2'
	option proto 'static'
	option device 'br-hotspot2'
	option ipaddr '192.168.20.1'
	option netmask '255.255.255.0'
	option delegate '0'

package openssl

package radius

config radius
	option disabled '0'
	option ca_cert '/etc/radius/ca.pem'
	option cert '/etc/radius/cert.pem'
	option key '/etc/radius/key.pem'
	option users '/etc/radius/users'
	option clients '/etc/radius/clients'
	option auth_port '18120'
	option acct_port '18120'

package rpcd

config rpcd
	option socket '/var/run/ubus/ubus.sock'
	option timeout '30'

config login
	option username 'root'
	option password '$p$root'
	list read '*'
	list write '*'

package setup

config setup 'default'
	option AlwSettings 'AL'
	option lan_ipaddr '192.168.1.11'
	option lan_netmask '255.255.255.0'
	option mode 'ap'
	option wifi_ssid 'Hotspot-1'
	option uplink_band '2g'
	option mesh_band '2g'
	option is_vlan '0'
	option vlan_id '10'
	option wifi_ssid_vlan_ip_suffix '0'
	option channel_2g '1'
	option channel_5g '36'
	option reset_button_disabled '0'
	option reset_hold_seconds '5'
	option wps_button_disabled '0'
	option initial_setup_complete '1'
	option hotspot_enabled_from_wizard '0'
	option wifi_ssid_5g_mode 'derived'
	option wifi_mode_2g 'ax'
	option wifi_width_2g '20'
	option wifi_mode_5g 'ax'
