{
	"unauthenticated": {
		"description": "Allow OTA status display without login when no password is set",
		"read": {
			"file": {
				"/usr/libexec/alemprator-ota/status-json": [ "exec" ],
				"/usr/libexec/alemprator-ota/internet-check": [ "exec" ]
			},
			"ubus": {
				"file": [ "exec" ],
				"system": [ "board" ]
			}
		}
	},

	"luci-app-alemprator-ota": {
		"description": "ALemprator OTA monitor and control",
		"read": {
			"uci": [ "alemprator_ota" ],
			"file": {
				"/usr/libexec/alemprator-ota/status-json": [ "exec" ],
				"/usr/libexec/alemprator-ota/internet-check": [ "exec" ],
				"/usr/libexec/alemprator-ota/manual-info": [ "exec" ]
			},
			"ubus": {
				"file": [ "exec" ],
				"system": [ "board" ]
			}
		},
		"write": {
			"cgi-io": [ "upload" ],
			"uci": [ "alemprator_ota" ],
			"file": {
				"/tmp/alemprator-ota/manual-update.bin": [ "write" ],
				"/usr/libexec/alemprator-ota/run-once": [ "exec" ],
				"/usr/libexec/alemprator-ota/manual-clear": [ "exec" ],
				"/usr/libexec/alemprator-ota/start-check": [ "exec" ],
				"/usr/libexec/alemprator-ota/start-manual-update": [ "exec" ],
				"/usr/libexec/alemprator-ota/start-update": [ "exec" ]
			},
			"ubus": {
				"file": [ "exec" ]
			}
		}
	}
}
