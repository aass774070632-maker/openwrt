#!/bin/sh
# Hotspot OpenWrt License Validator - By-passed
exit 0

# Tied to Alemprator OTA System
# Author: Antigravity

. /usr/libexec/alemprator-ota/common.sh

LICENSE_CACHE="/etc/alemprator/hotspot.license"
GRACE_PERIOD=$((3 * 86400)) # 3 days in seconds

sync_license_check_cache() {
    [ -x /usr/libexec/hotspot-openwrt/license-check ] || return 1
    /usr/libexec/hotspot-openwrt/license-check >/dev/null 2>&1 || return 1

    mkdir -p /etc/alemprator || return 1
    cat > "$LICENSE_CACHE" <<EOF
license_last_check='$NOW'
license_expires_at='$((NOW + GRACE_PERIOD))'
license_status='active'
EOF
    chmod 600 "$LICENSE_CACHE" 2>/dev/null || true
    return 0
}

load_config

# Ensure we have the server URL
[ -n "$SERVER_URL" ] || SERVER_URL="https://updates.example.com"

TOKEN=$(ensure_token)
NOW=$(date +%s)

# After a factory reset, newer guard/license-check may be valid while the legacy
# local cache is gone. Recreate the cache from license-check before falling back
# to the older OTA verification path used by this validator.
if sync_license_check_cache; then
    exit 0
fi

# 1. Check local cache first
if [ -f "$LICENSE_CACHE" ]; then
    . "$LICENSE_CACHE"
    # shellcheck disable=SC2154
    if [ "$NOW" -lt "$license_expires_at" ]; then
        # Authorized locally
        exit 0
    fi
fi

# 2. Try to verify with server
MODEL=$(get_device_model)
MAC=$(get_primary_mac)

# We use a custom endpoint for hotspot verification
# You should add this endpoint to your OTA server
VERIFY_PATH="/api/hotspot-verify"
PAYLOAD="{\"token\":\"$TOKEN\",\"model\":\"$MODEL\",\"mac\":\"$MAC\"}"
ACTION="hotspot_verify|$TOKEN|$MODEL|$MAC"

RESPONSE=$(signed_post_json "$SERVER_URL$VERIFY_PATH" "$PAYLOAD" "$ACTION" 2>/dev/null)
RET=$?

if [ $RET -eq 0 ] && [ -n "$RESPONSE" ]; then
    ACCEPTED=$(printf '%s' "$RESPONSE" | jsonfilter -e '@.accepted')
    if [ "$ACCEPTED" = "1" ] || [ "$ACCEPTED" = "true" ]; then
        # Success! Update cache
        EXPIRES=$((NOW + GRACE_PERIOD))
        cat > "$LICENSE_CACHE" <<EOF
license_last_check='$NOW'
license_expires_at='$EXPIRES'
license_status='active'
EOF
        exit 0
    elif [ "$ACCEPTED" = "0" ] || [ "$ACCEPTED" = "false" ]; then
        # Explicitly rejected
        echo "license_status='blocked'" > "$LICENSE_CACHE"
        exit 1
    fi
fi

# 3. If server unreachable, check if we are still within the grace period of the last check
# (This handles temporary internet outages)
if [ -f "$LICENSE_CACHE" ]; then
    . "$LICENSE_CACHE"
    if [ "$license_status" = "active" ] && [ "$NOW" -lt "$((license_expires_at + 86400))" ]; then
        # Allow 1 extra day if server is down but it was recently active
        exit 0
    fi
fi

# Not authorized
exit 1