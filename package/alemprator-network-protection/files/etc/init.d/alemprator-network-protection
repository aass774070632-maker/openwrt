#!/bin/sh /etc/rc.common

USE_PROCD=1
START=98
STOP=15
EXTRA_COMMANDS="recover status rstp_info"
EXTRA_HELP="    status    Show current protection status\n    recover   Attempt to recover all ports\n    rstp_info Show RSTP status for all bridges"

. /usr/libexec/alemprator-network-protection/common.sh

NP_CFG="alemprator-network-protection"

boot() {
	np_load_config
	local enabled
	config_get enabled main enabled 0
	[ "$enabled" != "1" ] && return 0

	np_log "info" "Starting Network Protection (boot)"

	local bridges
	bridges="$(np_get_bridges)"
	for br in $bridges; do
		np_bridge_exists "$br" || continue
		/usr/libexec/alemprator-network-protection/rstp-manager apply "$br"
	done

	# Signal procd to start the service (calls start_service in procd context)
	start
}

start_service() {
	np_load_config
	local enabled
	config_get enabled main enabled 0
	[ "$enabled" != "1" ] && {
		np_log "info" "Network Protection is disabled"
		return 0
	}

	np_init_state

	np_log "info" "Starting Network Protection v$NP_VERSION"

	/usr/libexec/alemprator-network-protection/logger rotate

	procd_open_instance
	procd_set_param command /usr/libexec/alemprator-network-protection/monitor
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 0
	procd_set_param stderr 1
	procd_close_instance

	local bridges
	bridges="$(np_get_bridges)"
	for br in $bridges; do
		np_bridge_exists "$br" || continue
		/usr/libexec/alemprator-network-protection/rstp-manager apply "$br"

		/usr/libexec/alemprator-network-protection/rstp-manager monitor "$br" >/dev/null 2>&1 </dev/null 3>&- 4>&- 5>&- 6>&- 7>&- 8>&- 9>&- 1000>&- &
		local rstp_pid=$!
		echo "$rstp_pid" > "$NP_RUN_DIR/rstp_monitor_${br}.pid"
	done

	local log_rotate_pid
	(
		while true; do
			sleep 300
			/usr/libexec/alemprator-network-protection/logger rotate 1048576
		done
	) >/dev/null 2>&1 </dev/null 3>&- 4>&- 5>&- 6>&- 7>&- 8>&- 9>&- 1000>&- &
	log_rotate_pid=$!
	echo "$log_rotate_pid" > "$NP_RUN_DIR/logger_rotate.pid"

	np_log "info" "Network Protection started"
}

stop_service() {
	np_log "info" "Stopping Network Protection via procd"

	np_cleanup_ifb

	local pid
	for pid_file in "$NP_RUN_DIR"/rstp_monitor_*.pid "$NP_RUN_DIR"/logger_rotate.pid; do
		[ -f "$pid_file" ] || continue
		pid="$(cat "$pid_file" 2>/dev/null)"
		[ -n "$pid" ] && kill "$pid" 2>/dev/null || true
		rm -f "$pid_file"
	done

	np_log "info" "Network Protection stopped"
}

reload_service() {
	np_log "info" "Reloading Network Protection configuration"
	# procd will handle the restart of the main instance
	# We just need to restart our extra background processes
	stop_service
	sleep 1
	start_service
}

service_triggers() {
	procd_add_reload_trigger "$NP_CFG"
}

show_status() {
	np_load_config
	local enabled
	config_get enabled main enabled 0
	echo "Network Protection: $( [ "$enabled" = "1" ] && echo 'enabled' || echo 'disabled')"
	echo ""

	/usr/libexec/alemprator-network-protection/detector status

	echo ""
	/usr/libexec/alemprator-network-protection/action-manager state

	echo ""
	/usr/libexec/alemprator-network-protection/port-isolation state

	echo ""
	/usr/libexec/alemprator-network-protection/logger stats
}

show_rstp_info() {
	local bridges
	bridges="$(np_get_bridges)"
	for br in $bridges; do
		np_bridge_exists "$br" || continue
		/usr/libexec/alemprator-network-protection/rstp-manager info "$br"
		echo ""
	done
}

# These functions are called directly by /etc/rc.common
# when the corresponding command is passed (e.g., "recover")
recover() {
	np_load_config
	local bridges
	bridges="$(np_get_bridges)"
	for br in $bridges; do
		np_bridge_exists "$br" || continue
		local ports
		ports="$(np_get_bridge_ports "$br")"
		for port in $ports; do
			/usr/libexec/alemprator-network-protection/action-manager recover "manual" "$port"
		done
	done
	np_log "info" "Manual recovery completed"
}

status_service() {
	show_status
}

rstp_info() {
	show_rstp_info
}
