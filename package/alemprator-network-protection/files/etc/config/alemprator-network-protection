config globals 'main'
	option enabled '1'
	option debug '0'
	option log_level 'info'
	option monitor_interval '5'
	option auto_recover '1'
	option recovery_delay '60'
	option max_actions_per_minute '10'
	option bridges 'br-lan'

config loop_protection 'loop'
	option enabled '1'
	option action 'warn'
	option max_mac_moves '5'
	option window_seconds '10'
	option auto_recover '1'
	option recovery_delay '60'
	option notify '1'

config broadcast_storm 'broadcast'
	option enabled '1'
	option action 'rate_limit'
	option max_pps '500'
	option max_ratio '30'
	option window_seconds '5'
	option storm_duration_seconds '3'
	option rate_limit_kbps '1000'
	option auto_recover '1'
	option recovery_delay '30'
	option notify '1'

config arp_storm 'arp'
	option enabled '1'
	option action 'warn'
	option max_arp_pps '100'
	option window_seconds '5'
	option storm_duration_seconds '3'
	option rate_limit_kbps '500'
	option auto_recover '1'
	option recovery_delay '30'
	option notify '1'
	option exclude_gateway '1'

config dhcp_rogue 'dhcp_rogue'
	option enabled '1'
	option action 'warn'
	option auto_block '0'
	option trusted_servers ''
	option notify '1'

config mac_flapping 'mac_flapping'
	option enabled '1'
	option action 'warn'
	option max_flaps '10'
	option window_seconds '30'
	option auto_recover '1'
	option recovery_delay '120'
	option notify '1'

config port_isolation 'port_isolation'
	option enabled '0'
	option default_action 'isolate'
	option quarantine_bridge 'br-lan'
	option guest_vlan '100'
	option notify '1'

config rstp 'rstp'
	option enabled '0'
	option bridge_priority '32768'
	option forward_delay '15'
	option hello_time '2'
	option max_age '20'
	option notify '1'

config trusted_dhcp 'trusted_dhcp'
	option mac '00:11:22:33:44:55'
	option comment 'Primary router'

config trusted_dhcp 'trusted_dhcp_2'
	option mac 'AA:BB:CC:DD:EE:FF'
	option comment 'Backup DHCP server'
