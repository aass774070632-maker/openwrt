config ota 'main'
	option enabled '1'
	option server_url 'https://ota.kartnet.org'
	option register_path '/api/register'
	option update_path '/api/update'
	option heartbeat_path '/api/heartbeat'
	option check_interval '21600'
	option random_delay_max '3600'
	option auto_upgrade '1'
	option require_setup_complete '0'
	option keep_config '1'
	option allow_force '1'
	option window_start '2'
	option window_end '6'
	option retry_base '900'
	option retry_max '21600'
	option token_salt 'CHANGE_ME_UNIQUE_PER_BRAND'
	option hmac_secret ''
	option connect_timeout '20'
	option model_file '/etc/model'
	option token_file '/etc/alemprator/device.token'
	option version_file '/etc/alemprator/firmware-version'
	option state_file '/tmp/alemprator-ota/state.env'
