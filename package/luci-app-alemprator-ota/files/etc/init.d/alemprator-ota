#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95

. /lib/functions.sh

CONFIG="alemprator_ota"

is_enabled() {
	local enabled=1
	config_load "$CONFIG"
	config_get enabled main enabled 1
	[ "$enabled" = "1" ]
}

start_service() {
	is_enabled || return 0

	procd_open_instance
	procd_set_param command /usr/libexec/alemprator-ota/agent.sh daemon
	procd_set_param respawn 3600 10 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	/usr/libexec/alemprator-ota/run-once --check-only >/dev/null 2>&1 || true
}

service_triggers() {
	procd_add_reload_trigger "$CONFIG"
}
