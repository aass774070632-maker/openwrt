#!/bin/sh

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

case "$1" in
	--check-only)
		exec "$SCRIPT_DIR/agent.sh" force-check
		;;
	--update-now)
		exec "$SCRIPT_DIR/agent.sh" update-now
		;;
	--register)
		exec "$SCRIPT_DIR/agent.sh" register
		;;
	*)
		exec "$SCRIPT_DIR/agent.sh" once
		;;
esac
