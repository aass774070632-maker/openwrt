{
	"luci-app-hotspot-openwrt": {
		"description": "Grant access for Hotspot OpenWrt wizard",
		"read": {
			"file": {
				"/usr/libexec/hotspot-openwrt/status-json": [ "exec" ],
				"/usr/libexec/hotspot-openwrt/validate": [ "exec" ]
			},
			"uci": [ "chilli", "dhcp", "firewall", "hotspot_openwrt", "network", "wireless" ],
			"ubus": {
				"system": [ "board" ],
				"network.interface": [ "dump" ],
				"network.wireless": [ "status" ]
			}
		},
		"write": {
			"cgi-io": [ "upload" ],
			"file": {
				"/tmp/hotspot-openwrt-upload": [ "write" ],
				"/usr/libexec/hotspot-openwrt/apply": [ "exec" ],
				"/usr/libexec/hotspot-openwrt/portal-upload": [ "exec" ],
				"/usr/libexec/hotspot-openwrt/validate": [ "exec" ]
			},
			"ubus": {
				"file": [ "exec" ]
			},
			"uci": [ "chilli", "dhcp", "firewall", "hotspot_openwrt", "network", "wireless" ]
		}
	}
}