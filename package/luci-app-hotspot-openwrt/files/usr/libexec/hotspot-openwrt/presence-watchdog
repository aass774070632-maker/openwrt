#!/bin/sh

primary_socket_path='/var/run/chilli_hotspot_openwrt.sock'
secondary_socket_path='/var/run/chilli_hotspot_openwrt_secondary.sock'
state_dir='/var/run/hotspot-openwrt-absent'

duration_to_seconds() {
	local value="$1" days='0' time_part seconds
	value="$(printf '%s' "$value" | tr 'A-Z' 'a-z' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
	case "$value" in ''|none|0) printf '0'; return 0 ;; esac
	case "$value" in *d*)
		days="$(printf '%s' "$value" | sed 's/d.*//;s/[^0-9]//g')"
		[ -n "$days" ] || days='0'
		value="$(printf '%s' "$value" | sed 's/^[^d]*d[[:space:]]*//')"
		;;
	esac
	case "$value" in
		*:*:*) time_part="$(printf '%s' "$value" | awk -F: '{ print ($1 * 3600) + ($2 * 60) + $3 }')" ;;
		*:*) time_part="$(printf '%s' "$value" | awk -F: '{ print ($1 * 60) + $2 }')" ;;
		*[0-9]h) time_part="$(printf '%s' "$value" | sed 's/[^0-9]//g' | awk '{ print $1 * 3600 }')" ;;
		*[0-9]m) time_part="$(printf '%s' "$value" | sed 's/[^0-9]//g' | awk '{ print $1 * 60 }')" ;;
		*[0-9]s) time_part="$(printf '%s' "$value" | sed 's/[^0-9]//g')" ;;
		*[!0-9]*) time_part='0' ;;
		*) time_part="$value" ;;
	esac
	seconds="$((days * 86400 + ${time_part:-0}))"
	printf '%s' "$seconds"
}

normalize_mac() {
	printf '%s' "$1" | tr 'A-Z-' 'a-z:'
}

valid_client_ip() {
	case "$1" in
		''|0.0.0.0|127.*|169.254.*|255.255.255.255|*[!0-9.]*) return 1 ;;
	esac
	printf '%s' "$1" | awk -F. 'NF == 4 { for (i = 1; i <= 4; i++) if ($i < 0 || $i > 255 || $i == "") exit 1; exit 0 } { exit 1 }'
}

associated_macs() {
	if command -v iw >/dev/null 2>&1; then
		# البحث في جميع الواجهات اللاسلكية المتوفرة في النظام
		for wlan in /sys/class/net/wlan* /sys/class/net/ath* /sys/class/net/wl*; do
			local iface
			iface="$(basename "$wlan")"
			[ -d "$wlan" ] || continue
			iw dev "$iface" station dump 2>/dev/null | awk '/^Station / { print $2 }'
		done
	fi
	# فحص جدول الـ Bridge كاحتياط للأجهزة المتصلة سلكياً أو لاسلكياً
	if command -v brctl >/dev/null 2>&1; then
		for br in br-hotspot br-hotspot2; do
			if [ -d "/sys/class/net/$br" ]; then
				brctl showmacs "$br" 2>/dev/null | awk 'NR > 1 && $3 == "no" { print $4 }'
			fi
		done
	fi
}

client_responds() {
	local ip="$1"
	valid_client_ip "$ip" || return 1
	ping -c 2 -W 1 "$ip" >/dev/null 2>&1
}

scan_chilli_socket() {
	local timeout="$1" instance="$2" socket_path="$3" mac ip state stamp_name stamp_file first_seen age normalized_mac client_file after_state
	[ -S "$socket_path" ] || return 0
	client_file="$state_dir/clients.${instance}.$$"
	chilli_query -s "$socket_path" list 2>/dev/null > "$client_file"
	while read mac ip state rest; do
		[ -n "$mac" ] && [ -n "$ip" ] || continue
		checked=$((checked + 1))
		normalized_mac="$(normalize_mac "$mac")"
		stamp_name="${instance}_$(printf '%s' "$normalized_mac" | tr ':' '_')"
		stamp_file="$state_dir/$stamp_name"
		printf '%s\n' "$stamp_name" >> "$current_file"
		   if grep -qx "$normalized_mac" "$associated_file" 2>/dev/null; then
			   # MAC مرتبط فعلياً بالواي فاي: اعتبره متصلاً فوراً.
			   rm -f "$stamp_file"
			   continue
		   fi
		   if ! valid_client_ip "$ip"; then
			   chilli_query -s "$socket_path" dhcp-release "$normalized_mac" >/dev/null 2>&1 || true
			   logger -t hotspot-openwrt-watchdog "released stale invalid-ip host instance=$instance mac=$normalized_mac ip=$ip state=$state"
			   rm -f "$stamp_file"
			   kicked=$((kicked + 1))
			   continue
		   fi
		   # لا تعتمد على bridge fdb أو ip neigh لأنها قد تبقى بعد فصل الجهاز.
		   if client_responds "$ip"; then
			   # رد على ping: اعتبره حاضراً حتى لو لم يظهر في iw مؤقتاً.
			   rm -f "$stamp_file"
			   continue
		   fi
		   # MAC غير مرتبط ولم يرد على ping: ابدأ عداد الغياب.
		   if [ ! -s "$stamp_file" ]; then
			   printf '%s\n' "$now" > "$stamp_file"
			   continue
		   fi
		   first_seen="$(cat "$stamp_file" 2>/dev/null)"
		   case "$first_seen" in ''|*[!0-9]*) first_seen="$now"; printf '%s\n' "$now" > "$stamp_file" ;; esac
		   age=$((now - first_seen))
		   if [ "$age" -ge "$timeout" ]; then
			   if [ "$state" = 'pass' ]; then
				   chilli_query -s "$socket_path" logout ip "$ip" >/dev/null 2>&1 || chilli_query -s "$socket_path" logout mac "$normalized_mac" >/dev/null 2>&1 || true
				   after_state="$(chilli_query -s "$socket_path" list 2>/dev/null | awk -v mac="$normalized_mac" -v ip="$ip" 'tolower($1) == mac || $2 == ip { print $3; found = 1; exit } END { if (!found) exit 0 }')"
				   logger -t hotspot-openwrt-watchdog "logged out disconnected active client instance=$instance mac=$normalized_mac ip=$ip absent_seconds=$age timeout=$timeout new_state=${after_state:-missing}"
			   else
				   chilli_query -s "$socket_path" dhcp-release "$normalized_mac" >/dev/null 2>&1 || true
				   logger -t hotspot-openwrt-watchdog "released disconnected host instance=$instance mac=$normalized_mac ip=$ip state=$state absent_seconds=$age timeout=$timeout"
			   fi
			   rm -f "$stamp_file"
			   kicked=$((kicked + 1))
		   fi
	done < "$client_file"
	rm -f "$client_file"
}

scan_once() {
	local timeout="$1" mode="$2" now kicked checked associated_file current_file stamp_file
	command -v chilli_query >/dev/null 2>&1 || return 0
	[ -S "$primary_socket_path" ] || [ -S "$secondary_socket_path" ] || return 0
	mkdir -p "$state_dir" || return 0
	now="$(date +%s)"
	kicked='0'
	checked='0'
	associated_file="$state_dir/associated.$$"
	current_file="$state_dir/current.$$"
	associated_macs | while read mac; do
		[ -n "$mac" ] && normalize_mac "$mac"
	done | sort -u > "$associated_file"
	: > "$current_file"
	scan_chilli_socket "$timeout" primary "$primary_socket_path"
	scan_chilli_socket "$timeout" secondary "$secondary_socket_path"
	for stamp_file in "$state_dir"/*; do
		[ -f "$stamp_file" ] || continue
		case "$(basename "$stamp_file")" in associated.*|connected.*|clients.*|current.*) continue ;; esac
		grep -qx "$(basename "$stamp_file")" "$current_file" 2>/dev/null || rm -f "$stamp_file"
	done
	rm -f "$associated_file" "$current_file"
	[ "$mode" = '--once' ] && printf '{"checked":%s,"kicked":%s}\n' "$checked" "$kicked"
}

timeout="$(duration_to_seconds "$(uci -q get hotspot_openwrt.main.keepalive_timeout || echo 00:02:00)")"
case "$timeout" in ''|*[!0-9]*) timeout='0' ;; esac
[ "$timeout" -gt 0 ] || exit 0

if [ "$1" = '--once' ]; then
	scan_once "$timeout" --once
	exit 0
fi

interval=$((timeout / 3))
[ "$interval" -ge 5 ] || interval='5'
[ "$interval" -le 30 ] || interval='30'

while :; do
	scan_once "$timeout"
	sleep "$interval"
done