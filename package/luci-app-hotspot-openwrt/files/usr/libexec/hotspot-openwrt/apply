#!/bin/sh

json_escape() {
	printf '%s' "$1" | awk '{ gsub(/\\/, "\\\\"); gsub(/"/, "\\\""); printf "%s%s", (NR>1 ? "\\n" : ""), $0 }'
}

json_bool() {
	[ "$1" = '1' ] && printf true || printf false
}

# Escape a value for safe embedding in a JS string literal (single or double
# quoted) inside HTML. Handles JSON-string escaping AND breaks </script>
# sequences to prevent stored XSS when admin-controlled UCI values are injected
# into settings.js / index.html (H1).
js_str_escape() {
	printf '%s' "$1" | awk '
		BEGIN { q = sprintf("%c", 39) }
		{
			gsub(/\\/, "\\\\")
			gsub(/"/, "\\\"")
			gsub(q, "\\" q)
			gsub(/</, "\\u003C")
			gsub(/>/, "\\u003E")
			gsub(/&/, "\\u0026")
			printf "%s%s", (NR>1 ? "\\n" : ""), $0
		}'
}

fail_json() {
	printf '{"ok":false,"stage":"%s","message":"%s"}\n' "$(json_escape "$1")" "$(json_escape "$2")"
	exit 1
}

last_octet() {
	printf '%s' "$1" | awk -F. 'NF == 4 { print $4 }'
}

network_for() {
	local ipaddr="$1" cidr="$2"
	/bin/ipcalc.sh "$ipaddr/$cidr" 2>/dev/null | awk -F= '$1 == "NETWORK" { print $2 }'
}

valid_ipv4() {
	case "$1" in ''|*[!0-9.]*) return 1 ;; esac
	printf '%s' "$1" | awk -F. 'NF == 4 { for (i = 1; i <= 4; i++) if ($i == "" || $i < 0 || $i > 255) exit 1; exit 0 } { exit 1 }'
}

valid_mac() {
	case "$1" in
		*[!0-9a-fA-F:]*) return 1 ;;
	esac
	printf '%s' "$1" | awk -F: 'NF == 6 { for (i = 1; i <= 6; i++) if (length($i) != 2) exit 1; exit 0 } { exit 1 }'
}

section_exists() {
	uci -q get "$1" >/dev/null 2>&1
}

zone_for_network() {
	local network="$1" section name networks item
	for section in $(uci -q show firewall | sed -n "s/^firewall\.\([^=]*\)=zone$/\1/p"); do
		name="$(uci -q get firewall.$section.name)"
		networks="$(uci -q get firewall.$section.network)"
		for item in $networks; do
			[ "$item" = "$network" ] && { printf '%s' "${name:-$section}"; return 0; }
		done
	done
	printf '%s' "$network"
}

zone_section_by_name() {
	local zone_name="$1" section name
	for section in $(uci -q show firewall | sed -n "s/^firewall\.\([^=]*\)=zone$/\1/p"); do
		name="$(uci -q get firewall.$section.name)"
		[ "$name" = "$zone_name" ] && { printf '%s' "$section"; return 0; }
	done
	return 1
}

enable_zone_masquerade() {
	local zone_name="$1" section
	section="$(zone_section_by_name "$zone_name")" || return 0
	uci set firewall.$section.masq='1'
	uci set firewall.$section.mtu_fix='1'
}

backup_configs() {
	BACKUP_DIR="/etc/hotspot-openwrt/backups/$(date +%Y%m%d-%H%M%S)"
	mkdir -p "$BACKUP_DIR" || return 1
	local package
	for package in network dhcp firewall chilli wireless hotspot_openwrt; do
		uci -q export "$package" > "$BACKUP_DIR/$package.uci" 2>/dev/null || true
	done
	RESTORE_DIR="$BACKUP_DIR"
	printf '%s' "$BACKUP_DIR"
}

verify_runtime() {
	local subscriber_interface="$1" hotspot_ip="$2" tun_device="${3:-tun0}"

	[ -c /dev/net/tun ] || { printf '%s' 'TUN device /dev/net/tun is missing'; return 1; }
	ip link show "$tun_device" >/dev/null 2>&1 || { printf '%s' "CoovaChilli did not create $tun_device"; return 1; }
	pidof chilli >/dev/null 2>&1 || { printf '%s' 'CoovaChilli process is not running'; return 1; }
	ip -4 addr show "$tun_device" 2>/dev/null | grep -q "[[:space:]]$hotspot_ip/" || { printf '%s' "$tun_device does not have the hotspot IP"; return 1; }

	if [ "$subscriber_interface" != 'lan' ] && ip link show br-lan >/dev/null 2>&1; then
		ip -4 addr show br-lan 2>/dev/null | grep -q 'inet ' || { printf '%s' 'br-lan is present but has no IPv4 management address'; return 1; }
	fi

	return 0
}

set_bridge_ports() {
	local device_section="$1" bridge_ports="$2" port section

	uci -q delete network.$device_section.ports
	for port in $(printf '%s' "$bridge_ports" | tr ',' ' '); do
		[ -n "$port" ] || continue
		for section in $(uci -q show network | sed -n "s/^network\.\([^=]*\)=device$/\1/p"); do
			uci -q del_list network.$section.ports="$port" || true
		done
		uci add_list network.$device_section.ports="$port"
	done
}

configure_wireless() {
	local wifi_iface="$1" subscriber_interface="$2"
	[ -n "$wifi_iface" ] || return 0
	section_exists "wireless.$wifi_iface" || fail_json 'wireless' "WiFi section '$wifi_iface' was not found"
	# Always enable the hotspot wifi interface on apply/start so clients can connect.
	uci set wireless.$wifi_iface.network="$subscriber_interface"
	uci set wireless.$wifi_iface.disabled='0'
	uci set wireless.$wifi_iface.isolate='1'
	uci commit wireless
}

first_wireless_radio() {
	uci -q show wireless | sed -n "s/^wireless\.\([^=]*\)=wifi-device$/\1/p" | head -n 1
}

wireless_radio_by_band() {
	local target_band="$1" section band

	for section in $(uci -q show wireless | sed -n "s/^wireless\.\([^=]*\)=wifi-device$/\1/p"); do
		band="$(uci -q get wireless.$section.band)"
		[ "$band" = "$target_band" ] && {
			printf '%s' "$section"
			return 0
		}
	done

	return 1
}

configure_quick_wireless() {
	local primary_interface="$1" secondary_interface="$2" primary_ssid="$3" secondary_ssid="$4" wifi_key="$5"
	local radio_2g radio_5g first_radio primary_radio secondary_radio encryption
	local section iface_mode networks item primary_disabled secondary_disabled

	primary_interface="$(normalize_interface_name "$primary_interface" 'hotspot')"
	secondary_interface="$(normalize_interface_name "$secondary_interface" 'hotspot2')"
	radio_2g="$(wireless_radio_by_band '2g')"
	radio_5g="$(wireless_radio_by_band '5g')"
	first_radio="$(first_wireless_radio)"

	primary_radio="$radio_2g"
	[ -n "$primary_radio" ] || primary_radio="$radio_5g"
	[ -n "$primary_radio" ] || primary_radio="$first_radio"
	[ -n "$primary_radio" ] || return 1

	secondary_radio="$radio_5g"
	[ -n "$secondary_radio" ] || secondary_radio="$radio_2g"
	[ -n "$secondary_radio" ] || secondary_radio="$primary_radio"

	[ -n "$primary_ssid" ] || primary_ssid='Hotspot-1'
	[ -n "$secondary_ssid" ] || secondary_ssid='Hotspot-2'
	[ -n "$wifi_key" ] || wifi_key="$(uci -q get wireless.wizard_hotspot_quick_primary.key)"
	[ -n "$wifi_key" ] || wifi_key="$(uci -q get wireless.wizard_hotspot_quick_secondary.key)"
	[ -n "$wifi_key" ] || wifi_key="$(uci -q get wireless.default_radio0.key)"
	[ -n "$wifi_key" ] || wifi_key="$(uci -q get wireless.default_radio1.key)"
	# Always enable hotspot interfaces on apply/start — never inherit a stale disabled=1.
	primary_disabled='0'
	secondary_disabled='0'

	encryption="$(uci -q get wireless.wizard_hotspot_quick_primary.encryption)"
	[ -n "$encryption" ] || encryption="$(uci -q get wireless.wizard_hotspot_quick_secondary.encryption)"
	[ -n "$encryption" ] || encryption='psk2'

	uci set wireless.wizard_hotspot_quick_primary=wifi-iface
	uci set wireless.wizard_hotspot_quick_primary.device="$primary_radio"
	uci set wireless.wizard_hotspot_quick_primary.mode='ap'
	uci set wireless.wizard_hotspot_quick_primary.network="$primary_interface"
	uci set wireless.wizard_hotspot_quick_primary.ssid="$primary_ssid"
	uci set wireless.wizard_hotspot_quick_primary.disabled="$primary_disabled"
	uci set wireless.wizard_hotspot_quick_primary.disassoc_low_ack='0'
	uci set wireless.wizard_hotspot_quick_primary.isolate='1'

	uci set wireless.wizard_hotspot_quick_secondary=wifi-iface
	uci set wireless.wizard_hotspot_quick_secondary.device="$secondary_radio"
	uci set wireless.wizard_hotspot_quick_secondary.mode='ap'
	uci set wireless.wizard_hotspot_quick_secondary.network="$secondary_interface"
	uci set wireless.wizard_hotspot_quick_secondary.ssid="$secondary_ssid"
	uci set wireless.wizard_hotspot_quick_secondary.disabled="$secondary_disabled"
	uci set wireless.wizard_hotspot_quick_secondary.disassoc_low_ack='0'
	uci set wireless.wizard_hotspot_quick_secondary.isolate='1'

	if [ -n "$wifi_key" ]; then
		[ "$encryption" = 'none' ] && encryption='psk2'
		uci set wireless.wizard_hotspot_quick_primary.encryption="$encryption"
		uci set wireless.wizard_hotspot_quick_primary.key="$wifi_key"
		uci set wireless.wizard_hotspot_quick_secondary.encryption="$encryption"
		uci set wireless.wizard_hotspot_quick_secondary.key="$wifi_key"
	else
		uci set wireless.wizard_hotspot_quick_primary.encryption='none'
		uci -q delete wireless.wizard_hotspot_quick_primary.key
		uci set wireless.wizard_hotspot_quick_secondary.encryption='none'
		uci -q delete wireless.wizard_hotspot_quick_secondary.key
	fi

	for section in $(uci -q show wireless | sed -n "s/^wireless\.\([^=]*\)=wifi-iface$/\1/p"); do
		[ "$section" = 'wizard_hotspot_quick_primary' ] && continue
		[ "$section" = 'wizard_hotspot_quick_secondary' ] && continue

		iface_mode="$(uci -q get wireless.$section.mode)"
		[ -n "$iface_mode" ] && [ "$iface_mode" != 'ap' ] && continue

		networks="$(uci -q get wireless.$section.network)"
		for item in $networks; do
			if [ "$item" = 'wizardvlan' ]; then
				case "$section" in hotspot_*|*hotspot*|wizard_*) uci -q delete wireless."$section" ;; esac
				break
			fi
			if [ "$item" = 'lan' ]; then
				case "$section" in hotspot_*|*hotspot*|wizard_*) uci set wireless."$section".disabled='1' ;; esac
				break
			fi
		done
	done

	uci commit wireless
	return 0
}

configure_chilli_local_access() {
	local config_file='/etc/chilli/config' temp_file="/tmp/hotspot-openwrt-chilli-config.$$"

	mkdir -p /etc/chilli
	if [ -f "$config_file" ]; then
		sed '/^# Hotspot OpenWrt managed access$/,/^# End Hotspot OpenWrt managed access$/d' "$config_file" > "$temp_file" || return 1
	else
		: > "$temp_file" || return 1
	fi

	cat >> "$temp_file" <<-'EOF'
	# Hotspot OpenWrt managed access
	HS_TCP_PORTS="80,443"
	# End Hotspot OpenWrt managed access
	EOF
	mv "$temp_file" "$config_file"
	chmod 0644 "$config_file" 2>/dev/null || true
}

configure_dnsmasq_compat() {
	local hotspot_ip="$1" portal_path="$2" captive_notify="$3" domain="$4" secondary_hotspot_ip="$5" dns1="$6" dns2="$7"
	local config_dir='/etc/dnsmasq.d' config_file='/etc/dnsmasq.d/hotspot-openwrt.conf'
	local current_address

	mkdir -p "$config_dir" || return 1
	mkdir -p /etc/hotspot-openwrt || return 1
	chmod 0755 "$config_dir" 2>/dev/null || true
	cat > "$config_file" <<-EOF
	# Hotspot OpenWrt captive portal compatibility
	filter-rr=HTTPS
	filter-rr=SVCB
	EOF
	valid_ipv4 "$dns1" || dns1=''
	valid_ipv4 "$dns2" || dns2=''
	[ -n "$dns1" ] && printf 'server=%s\n' "$dns1" >> "$config_file"
	[ -n "$dns2" ] && [ "$dns2" != "$dns1" ] && printf 'server=%s\n' "$dns2" >> "$config_file"
	case "$domain" in
		''|*[!A-Za-z0-9.-]*|.*|*.) domain='' ;;
	esac
	if [ -n "$domain" ]; then
		local hosts_tmp="/etc/.hosts.hotspot.tmp"
		grep -v "[[:space:]]$domain$" /etc/hosts 2>/dev/null > "$hosts_tmp" || : > "$hosts_tmp"
		printf '%s %s\n' "$hotspot_ip" "$domain" >> "$hosts_tmp"
		[ -n "$secondary_hotspot_ip" ] && [ "$secondary_hotspot_ip" != "$hotspot_ip" ] && printf '%s %s\n' "$secondary_hotspot_ip" "$domain" >> "$hosts_tmp"
		mv "$hosts_tmp" /etc/hosts || return 1
	fi
	if [ "$captive_notify" = '1' ]; then
		printf 'dhcp-option=114,http://%s%s/api.json\n' "$hotspot_ip" "$portal_path" >> "$config_file"
	fi
	chmod 0644 "$config_file" 2>/dev/null || true
	uci -q delete dhcp.@dnsmasq[0].confdir
	uci -q delete dhcp.@dnsmasq[0].addnhosts
	if [ -n "$domain" ]; then
		for current_address in $(uci -q get dhcp.@dnsmasq[0].address); do
			case "$current_address" in
				"/$domain/"*) uci -q del_list dhcp.@dnsmasq[0].address="$current_address" || true ;;
			esac
		done
		uci set dhcp.@dnsmasq[0].localise_queries='1'
	fi
	for current_address in $(uci -q get dhcp.@dnsmasq[0].address); do
		case "$current_address" in
			*/20.20.20.1|/connectivitycheck.gstatic.com/*|/connectivitycheck.android.com/*|/clients3.google.com/*|/msftconnecttest.com/*|/msftncsi.com/*|/apple.com/*)
				uci -q del_list dhcp.@dnsmasq[0].address="$current_address" || true
				;;
		esac
	done
	uci -q delete dhcp.@dnsmasq[0].dhcp_option="114,http://$hotspot_ip$portal_path/api.json" || true
	[ "$captive_notify" = '1' ] && uci add_list dhcp.@dnsmasq[0].dhcp_option="114,http://$hotspot_ip$portal_path/api.json"
	uci -q delete dhcp.@dnsmasq[0].interface
	uci set dhcp.@dnsmasq[0].nonwildcard='0'
	uci set dhcp.@dnsmasq[0].localservice='0'
	uci set dhcp.@dnsmasq[0].filter_aaaa='1'
	uci commit dhcp
}

ensure_dnsmasq_running() {
	/etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
	/etc/init.d/dnsmasq status >/dev/null 2>&1 && return 0

	local init_file='/etc/init.d/dnsmasq' backup_file='/etc/init.d/dnsmasq.hotspot-jail-backup'
	[ -f "$init_file" ] || return 1
	grep -q '^[[:space:]]*procd_add_jail dnsmasq ubus log$' "$init_file" || return 1
	[ -f "$backup_file" ] || cp "$init_file" "$backup_file" 2>/dev/null || true
	sed -i '/^[[:space:]]*procd_add_jail dnsmasq ubus log$/,/^[[:space:]]*\[ -e "\$hostsfile" \] && procd_add_jail_mount \$hostsfile$/s/^/# hotspot-openwrt: jail disabled: /' "$init_file" 2>/dev/null || return 1
	/etc/init.d/dnsmasq enable >/dev/null 2>&1 || true
	/etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
	/etc/init.d/dnsmasq status >/dev/null 2>&1
}

configure_domain_landing() {
	local hotspot_ip="$1" portal_path="$2" domain="$3" secondary_hotspot_ip="$4" index_file='/www/index.html' backup_file='/www/index.html.hotspot-openwrt.orig'
	case "$domain" in
		''|*[!A-Za-z0-9.-]*|.*|*.) return 0 ;;
	esac
	case "$portal_path" in
		/*) ;;
		*) portal_path='/hotspot' ;;
	esac
	[ -f "$backup_file" ] || cp "$index_file" "$backup_file" 2>/dev/null || true
	local esc_domain esc_ip esc_sec_ip esc_portal
	esc_domain="$(js_str_escape "$domain")"
	esc_ip="$(js_str_escape "$hotspot_ip")"
	esc_sec_ip="$(js_str_escape "$secondary_hotspot_ip")"
	esc_portal="$(js_str_escape "$portal_path")"
	cat > "$index_file" <<-EOF
	<!doctype html>
	<html>
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>OpenWrt</title>
		<script>
		(function() {
			var hostname = String(location.hostname || '').toLowerCase();
			var domain = '$esc_domain'.toLowerCase();
			if (hostname === domain || hostname === '$esc_ip' || hostname === '$esc_sec_ip')
				location.replace('http://' + location.hostname + '$esc_portal/status.html');
		})();
		</script>
	</head>
	<body>
		<a href="/cgi-bin/luci/">LuCI - Lua Configuration Interface</a>
	</body>
	</html>
	EOF
	chmod 0644 "$index_file" 2>/dev/null || true
}

configure_portal_files() {
	local hotspot_ip="$1" portal_path="$2" portal_storage_path="$3" terms_enabled="$4"
	local browser_cookie_enabled="$5" browser_cookie_days="$6" open_status_page="$7" status_autorefresh_seconds="$8"
	local mikrotik_compat="$9"
	local source_dir='/www/hotspot'
	local login_url status_url post_login_url radius_routing_list
	radius_routing_list="$(uci -q get hotspot_openwrt.main.radius_routing | tr '\n' ',' | sed 's/,$//')"

	case "$portal_path" in
		/*) ;;
		*) portal_path="/hotspot" ;;
	esac
	case "$portal_storage_path" in
		/www/*|/www) ;;
		*) portal_storage_path="/www$portal_path" ;;
	esac

	mkdir -p "$portal_storage_path" || return 1
	if [ "$portal_storage_path" != "$source_dir" ] && [ -d "$source_dir" ]; then
		# If compabitility mode is off, we ensure basic files exist
		if [ "$mikrotik_compat" != '1' ]; then
			cp "$source_dir/login.html" "$portal_storage_path/login.html" 2>/dev/null || true
			cp "$source_dir/status.html" "$portal_storage_path/status.html" 2>/dev/null || true
			cp "$source_dir/terms.html" "$portal_storage_path/terms.html" 2>/dev/null || true
			cp "$source_dir/style.css" "$portal_storage_path/style.css" 2>/dev/null || true
		fi
	fi

	if [ "$mikrotik_compat" = '1' ]; then
		login_url="http://$hotspot_ip/cgi-bin/mikrotik-gate"
	elif [ "$terms_enabled" = '1' ]; then
		login_url="http://$hotspot_ip$portal_path/terms.html"
	else
		login_url="http://$hotspot_ip$portal_path/login.html"
	fi
	status_url="http://$hotspot_ip$portal_path/status.html"
	case "$open_status_page" in
		always|http-login) post_login_url="dynamic" ;;
		none) post_login_url='http://connectivitycheck.gstatic.com/generate_204' ;;
		*) open_status_page='always'; post_login_url="dynamic" ;;
	esac
	cat > "$portal_storage_path/api.json" <<-EOF
	{"captive":true,"user-portal-url":"$login_url","venue-info-url":"$login_url","can-extend-session":true}
	EOF
	cat > "$portal_storage_path/settings.js" <<-EOF
	window.HOTSPOT_OPENWRT_SETTINGS={browserCookieEnabled:$([ "$browser_cookie_enabled" = '1' ] && echo true || echo false),browserCookieDays:$(printf '%s' "$browser_cookie_days" | awk '{ v=$1+0; if (v < 1) v=7; if (v > 365) v=365; print v }'),openStatusPage:"$open_status_page",postLoginUrl:$(if [ "$post_login_url" = 'dynamic' ]; then printf '("http://"+window.location.hostname+"%s/status.html")' "$portal_path"; else printf '"%s"' "$post_login_url"; fi),statusAutorefreshSeconds:$(printf '%s' "$status_autorefresh_seconds" | awk '{ v=$1+0; if (v < 0) v=0; if (v > 86400) v=86400; print v }'),networkName:"$(js_str_escape "$network_name")",supportPhone:"$(js_str_escape "$support_phone")",logoUrl:"$(js_str_escape "$logo_url")",noticeText:"$(js_str_escape "$notice_text")",liveStreamEnabled:$([ "$live_stream_enabled" = '1' ] && echo true || echo false),liveStreamUrl:"$(js_str_escape "$live_stream_url")",restAreaEnabled:$([ "$rest_area_enabled" = '1' ] && echo true || echo false),restAreaUrl:"$(js_str_escape "$rest_area_url")",loginMode:"$(js_str_escape "${login_mode:-both}")",availableSpeeds:"$(js_str_escape "$available_speeds")",speedtestEnabled:$([ "$speedtest_enabled" = '1' ] && echo true || echo false),speedtestUrl:"$(js_str_escape "$speedtest_url")",radiusRouting:"$(js_str_escape "$radius_routing_list")"};
	EOF
	chmod 0644 "$portal_storage_path/api.json" "$portal_storage_path/settings.js" 2>/dev/null || true
}

captive_portal_dhcpopt() {
	local hotspot_ip="$1" portal_path="$2" url length hex
	url="http://$hotspot_ip$portal_path/api.json"
	length="$(printf '%s' "$url" | wc -c | awk '{ print $1 + 0 }')"
	[ "$length" -gt 0 ] && [ "$length" -le 255 ] || return 1
	if command -v hexdump >/dev/null 2>&1; then
		hex="$(printf '%s' "$url" | hexdump -ve '1/1 "%02x"' 2>/dev/null)"
	else
		hex="$(printf '%s' "$url" | od -An -tx1 2>/dev/null | tr -d ' \n')"
	fi
	[ -n "$hex" ] || return 1
	printf '72%02x%s' "$length" "$hex"
}

duration_to_seconds() {
	local value="$1" days='0' time_part seconds
	value="$(printf '%s' "$value" | tr 'A-Z' 'a-z' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
	case "$value" in ''|none|0) printf '0'; return 0 ;; esac
	case "$value" in *d*)
		days="$(printf '%s' "$value" | sed 's/d.*//;s/[^0-9]//g')"
		[ -n "$days" ] || days='0'
		value="$(printf '%s' "$value" | sed 's/^[^d]*d[[:space:]]*//')"
		;;
	esac
	case "$value" in
		*:*:*) time_part="$(printf '%s' "$value" | awk -F: '{ print ($1 * 3600) + ($2 * 60) + $3 }')" ;;
		*:*) time_part="$(printf '%s' "$value" | awk -F: '{ print ($1 * 60) + $2 }')" ;;
		*[0-9]h) time_part="$(printf '%s' "$value" | sed 's/[^0-9]//g' | awk '{ print $1 * 3600 }')" ;;
		*[0-9]m) time_part="$(printf '%s' "$value" | sed 's/[^0-9]//g' | awk '{ print $1 * 60 }')" ;;
		*[0-9]s) time_part="$(printf '%s' "$value" | sed 's/[^0-9]//g')" ;;
		*[!0-9]*) time_part='0' ;;
		*) time_part="$value" ;;
	esac
	seconds="$((days * 86400 + ${time_part:-0}))"
	printf '%s' "$seconds"
}

bandwidth_to_bps() {
	local value="$1" number suffix
	value="$(printf '%s' "$value" | tr 'A-Z' 'a-z' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
	case "$value" in ''|none|0) printf '0'; return 0 ;; esac
	number="$(printf '%s' "$value" | sed 's/[^0-9].*$//')"
	[ -n "$number" ] || { printf '0'; return 0; }
	suffix="$(printf '%s' "$value" | sed 's/^[0-9]*//;s/[[:space:]]//g')"
	case "$suffix" in
		g*) printf '%s' "$((number * 1000000000))" ;;
		m*) printf '%s' "$((number * 1000000))" ;;
		k*) printf '%s' "$((number * 1000))" ;;
		*) printf '%s' "$number" ;;
	esac
}

normalize_interface_name() {
	local value="$1" fallback="$2"

	case "$value" in
		[A-Za-z0-9_][A-Za-z0-9_.-]*) printf '%s' "$value" ;;
		*) printf '%s' "$fallback" ;;
	esac
}

derive_secondary_interface() {
	local primary="$1" candidate

	primary="$(normalize_interface_name "$primary" 'hotspot')"
	candidate="${primary}2"

	[ "$candidate" = "$primary" ] && candidate="${primary}_2"
	printf '%s' "$(normalize_interface_name "$candidate" 'hotspot2')"
}

csv_append_unique() {
	local list="$1" additions="$2" item

	for item in $(printf '%s' "$additions" | tr ',' ' '); do
		[ -n "$item" ] || continue
		case ",$list," in
			*",$item,"*) ;;
			*) list="${list:+$list,}$item" ;;
		esac
	done

	printf '%s' "$list"
}

configure_walled_garden() {
	local section="$1" domains="$2" ips="$3" allowed

	allowed="$(uci -q get chilli.$section.uamallowed)"

	if [ -n "$domains" ]; then
		uci set chilli.$section.uamdomain="$domains"
		allowed="$(csv_append_unique "$allowed" "$domains")"
	else
		uci -q delete chilli.$section.uamdomain
	fi

	if [ -n "$ips" ]; then
		allowed="$(csv_append_unique "$allowed" "$ips")"
	fi

	if [ -n "$allowed" ]; then
		uci set chilli.$section.uamallowed="$allowed"
	else
		uci -q delete chilli.$section.uamallowed
	fi
}

quick_policy_limits() {
	local policy="$1" default_up="$2" default_down="$3" default_shared="$4"
	local normalized rate_rx rate_tx bandwidth_up bandwidth_down shared_users

	normalized="$(printf '%s' "$policy" | tr 'A-Z' 'a-z' | tr -d ' \t\r\n')"
	bandwidth_up="$default_up"
	bandwidth_down="$default_down"
	shared_users="$default_shared"

	case "$normalized" in
		*/*)
		rate_rx="${normalized%%/*}"
			rate_tx="${normalized##*/}"
			bandwidth_down="$(bandwidth_to_bps "$rate_rx")"
			bandwidth_up="$(bandwidth_to_bps "$rate_tx")"
			;;
		basic|economy)
			bandwidth_up='2000000'
			bandwidth_down='4000000'
			shared_users='2'
			;;
		guest)
			bandwidth_up='1000000'
			bandwidth_down='3000000'
			shared_users='1'
			;;
		standard)
			bandwidth_up='5000000'
			bandwidth_down='10000000'
			shared_users='3'
			;;
		staff)
			bandwidth_up='10000000'
			bandwidth_down='20000000'
			shared_users='5'
			;;
		trial)
			bandwidth_up='1000000'
			bandwidth_down='2000000'
			shared_users='1'
			;;
		'')
			bandwidth_up='5000000'
			bandwidth_down='10000000'
			shared_users='3'
			;;
		premium)
			bandwidth_up='15000000'
			bandwidth_down='30000000'
			shared_users='8'
			;;
		vip|ultra)
			bandwidth_up='30000000'
			bandwidth_down='60000000'
			shared_users='12'
			;;
		unlimited|none)
			bandwidth_up='0'
			bandwidth_down='0'
			;;
	esac

	printf '%s;%s;%s' "$bandwidth_up" "$bandwidth_down" "$shared_users"
}

configure_firewall_nft_compat() {
	local hotspot_net="$1" hotspot_cidr="$2" wan_interface="$3" secondary_hotspot_net="$4" secondary_hotspot_cidr="$5"
	local config_file='/etc/nftables.d/90-hotspot-openwrt-forward-nat.nft'

	# Older builds wrote independent nft base chains here. An accept verdict in a
	# custom base chain does not prevent fw4's later forward chain from rejecting
	# the same packet, which leaves logged-in clients with no internet. The package
	# firewall include now injects jumps into fw4's official forward/srcnat chains.
	rm -f "$config_file"
	[ -x /etc/hotspot-openwrt/firewall.sh ] && /etc/hotspot-openwrt/firewall.sh >/dev/null 2>&1 || true
	return 0
}

# Configure the router WAN connection (internet uplink to MikroTik).
# Supports DHCP (default) and PPPoE client modes.
setup_wan_connection() {
	[ "$wan_connection_type" = 'pppoe' ] || wan_connection_type='dhcp'

	# Ensure the wan network section exists.
	uci -q get network.wan >/dev/null 2>&1 || uci set network.wan='interface'

	case "$wan_connection_type" in
		pppoe)
			[ -n "$wan_pppoe_device" ] || wan_pppoe_device='eth0'
			uci -q batch <<-EOF
				set network.wan.proto='pppoe'
				set network.wan.device='$wan_pppoe_device'
				set network.wan.username='$wan_pppoe_username'
				set network.wan.password='$wan_pppoe_password'
				set network.wan.peerdns='1'
				set network.wan.ipv6='0'
			EOF
			logger -t hotspot-openwrt "WAN set to PPPoE on $wan_pppoe_device (user: $wan_pppoe_username)"
			;;
		*)
			uci -q batch <<-EOF
				set network.wan.proto='dhcp'
				delete network.wan.device
				delete network.wan.username
				delete network.wan.password
			EOF
			;;
	esac
}

