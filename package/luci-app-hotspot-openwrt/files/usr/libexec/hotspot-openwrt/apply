	acct_interim="$(uci -q get hotspot_openwrt.main.acct_interim)"
	coa_enabled="$(uci -q get hotspot_openwrt.main.coa_enabled)"
	coa_port="$(uci -q get hotspot_openwrt.main.coa_port)"
