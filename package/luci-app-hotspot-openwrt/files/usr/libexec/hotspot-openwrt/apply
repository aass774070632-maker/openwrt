	support_phone="$(uci -q get hotspot_openwrt.main.support_phone)"
	logo_url="$(uci -q get hotspot_openwrt.main.logo_url)"
	notice_text="$(uci -q get hotspot_openwrt.main.notice_text)"
	live_stream_enabled="$(uci -q get hotspot_openwrt.main.live_stream_enabled)"
	live_stream_url="$(uci -q get hotspot_openwrt.main.live_stream_url)"
	rest_area_enabled="$(uci -q get hotspot_openwrt.main.rest_area_enabled)"
	rest_area_url="$(uci -q get hotspot_openwrt.main.rest_area_url)"
	login_mode="$(uci -q get hotspot_openwrt.main.login_mode)"
	available_speeds="$(uci -q get hotspot_openwrt.main.available_speeds)"
	speedtest_enabled="$(uci -q get hotspot_openwrt.main.speedtest_enabled)"
speedtest_url="$(uci -q get hotspot_openwrt.main.speedtest_url)"
	quick_setup_enabled="$(uci -q get hotspot_openwrt.main.quick_setup_enabled)"
	quick_runtime_dual_enabled="$(uci -q get hotspot_openwrt.main.quick_runtime_dual_enabled)"
	quick_subscriber_interface="$(normalize_interface_name "$(uci -q get hotspot_openwrt.main.quick_subscriber_interface)" "$subscriber_interface")"
	quick_subscriber_interface_secondary="$(normalize_interface_name "$(uci -q get hotspot_openwrt.main.quick_subscriber_interface_secondary)" "$(derive_secondary_interface "$quick_subscriber_interface")")"
	quick_ssid_primary="$(uci -q get hotspot_openwrt.main.quick_ssid_primary)"
	quick_ssid_secondary="$(uci -q get hotspot_openwrt.main.quick_ssid_secondary)"
	quick_wifi_key="$(uci -q get setup.default.wifi_key)"
	quick_gateway_primary="$(uci -q get hotspot_openwrt.main.quick_gateway_primary)"
	quick_pool_start_primary="$(uci -q get hotspot_openwrt.main.quick_pool_start_primary)"
	quick_pool_end_primary="$(uci -q get hotspot_openwrt.main.quick_pool_end_primary)"
	quick_policy_primary="$(uci -q get hotspot_openwrt.main.quick_policy_primary)"
	quick_gateway_secondary="$(uci -q get hotspot_openwrt.main.quick_gateway_secondary)"
	quick_pool_start_secondary="$(uci -q get hotspot_openwrt.main.quick_pool_start_secondary)"
	quick_pool_end_secondary="$(uci -q get hotspot_openwrt.main.quick_pool_end_secondary)"
	quick_policy_secondary="$(uci -q get hotspot_openwrt.main.quick_policy_secondary)"
	[ -n "$portal_path" ] || portal_path='/hotspot'
	[ -n "$portal_storage_path" ] || portal_storage_path='/www/hotspot'
	[ -n "$browser_cookie_days" ] || browser_cookie_days='7'
	[ -n "$mtu" ] || mtu='1400'
	[ -n "$txqueuelen" ] || txqueuelen='500'
	[ -n "$sndbuf" ] || sndbuf='0'
	[ -n "$rcvbuf" ] || rcvbuf='0'
	case "$bridge_ageing_time" in ''|*[!0-9]*) bridge_ageing_time='10' ;; esac
	[ "$bridge_ageing_time" -ge 1 ] 2>/dev/null && [ "$bridge_ageing_time" -le 86400 ] 2>/dev/null || bridge_ageing_time='10'
	[ -n "$open_status_page" ] || open_status_page='always'
	[ -n "$session_timeout" ] || session_timeout='none'
	[ -n "$idle_timeout" ] || idle_timeout='none'
	[ -n "$status_autorefresh" ] || status_autorefresh='00:01:00'
	[ -n "$shared_users" ] || shared_users='3'
	[ -n "$acct_interim" ] || acct_interim='60'
	[ -n "$coa_port" ] || coa_port='3799'
	case "$coa_port" in ''|*[!0-9]*) coa_port='3799' ;; esac
	[ "$coa_port" -ge 1 ] 2>/dev/null && [ "$coa_port" -le 65535 ] 2>/dev/null || coa_port='3799'
	[ -n "$trial_duration" ] || trial_duration='30'
	[ -n "$trial_uptime_limit" ] || trial_uptime_limit='30'
	[ -n "$mac_auth_suffix" ] || mac_auth_suffix='@mac'
	[ -n "$uamssl_cert" ] || uamssl_cert='/etc/chilli/hotspot.crt'
	[ -n "$uamssl_key" ] || uamssl_key='/etc/chilli/hotspot.key'
	[ -n "$radius_nas_ip" ] || radius_nas_ip="$(ip -4 addr show br-lan 2>/dev/null | awk '/inet / { sub(/\/.*/, "", $2); print $2; exit }')"

	# Validate RADIUS secret
	if [ -z "$radius_secret" ]; then
		logger -t hotspot-audit "FATAL: RADIUS secret is empty"
		printf 'FATAL: RADIUS secret is empty\n' >&2
		return 1
	fi
	if [ "${#radius_secret}" -lt 8 ]; then
		logger -t hotspot-audit "FATAL: RADIUS secret is too short (min 8 chars, got ${#radius_secret})"
		printf 'FATAL: RADIUS secret is too short (min 8 chars, got %s)\n' "${#radius_secret}" >&2
		return 1
	fi
	[ -n "$radius_server2" ] || radius_server2="$radius_server"
	session_timeout_seconds="$(duration_to_seconds "$session_timeout")"
	idle_timeout_seconds="$(duration_to_seconds "$idle_timeout")"
	status_autorefresh_seconds="$(duration_to_seconds "$status_autorefresh")"
	rate_rx="$(printf '%s' "$rate_limit_rx_tx" | awk -F/ '{ print $1 }')"
	rate_tx="$(printf '%s' "$rate_limit_rx_tx" | awk -F/ '{ print $2 }')"
	bandwidth_down="$(bandwidth_to_bps "$rate_rx")"
	bandwidth_up="$(bandwidth_to_bps "$rate_tx")"
	[ -n "$quick_setup_enabled" ] || quick_setup_enabled='0'
	[ -n "$quick_runtime_dual_enabled" ] || quick_runtime_dual_enabled="$quick_setup_enabled"
	[ -n "$quick_policy_primary" ] || quick_policy_primary='standard'
	[ -n "$quick_policy_secondary" ] || quick_policy_secondary='premium'
	[ -n "$quick_ssid_primary" ] || quick_ssid_primary="$network_name"
	[ -n "$quick_ssid_primary" ] || quick_ssid_primary='Hotspot-1'
	[ -n "$quick_ssid_secondary" ] || quick_ssid_secondary='Hotspot-2'

	dual_quick_mode='0'
	if [ "$quick_setup_enabled" = '1' ]; then
		local quick_wan_iface="$(uci -q get hotspot_openwrt.main.quick_wan_interface)"
		[ -n "$quick_wan_iface" ] && wan_interface="$(normalize_interface_name "$quick_wan_iface" "$wan_interface")"
		subscriber_interface="$(normalize_interface_name "$quick_subscriber_interface" "$subscriber_interface")"
		[ -n "$quick_gateway_primary" ] && hotspot_ip="$quick_gateway_primary"
		[ -n "$quick_pool_start_primary" ] && pool_start="$quick_pool_start_primary"
		[ -n "$quick_pool_end_primary" ] && pool_end="$quick_pool_end_primary"

		if [ "$quick_runtime_dual_enabled" != '0' ]; then
			dual_quick_mode='1'
			secondary_subscriber_interface="$(normalize_interface_name "$quick_subscriber_interface_secondary" "$(derive_secondary_interface "$subscriber_interface")")"
			secondary_hotspot_ip="${quick_gateway_secondary:-192.168.20.1}"
			secondary_hotspot_cidr="${hotspot_cidr:-24}"
			secondary_pool_start="${quick_pool_start_secondary:-192.168.20.10}"
			secondary_pool_end="${quick_pool_end_secondary:-192.168.20.199}"
			if [ "$secondary_subscriber_interface" = "$subscriber_interface" ]; then
				secondary_subscriber_interface="$(derive_secondary_interface "$subscriber_interface")"
			fi
		fi
	fi
	dns1="$(uci -q get hotspot_openwrt.main.dns1)"
	dns2="$(uci -q get hotspot_openwrt.main.dns2)"
	[ -n "$dns1" ] || dns1='8.8.8.8'
	[ -n "$dns2" ] || dns2="$dns1"
	walled_garden="$(uci -q get hotspot_openwrt.main.walled_garden | tr ' ' ',')"
	walled_garden_ip="$(uci -q get hotspot_openwrt.main.walled_garden_ip | tr ' ' ',')"
	mac_allowed="$(uci -q show hotspot_openwrt.main.ip_binding 2>/dev/null | sed "s/^.*='//;s/'$//" | awk 'tolower($1) == "bypassed" { print $2 }' | tr 'A-Z-' 'a-z:' | tr '\n' ',' | sed 's/,$//')"
	old_secondary_subscriber_interface="$(normalize_interface_name "$(uci -q get hotspot_openwrt.main.quick_subscriber_interface_secondary)" '')"

	backup_file="$(backup_configs)" || fail_json 'backup' 'Could not create configuration backup'
	backup_dir="$backup_file"
	calc_output="$(/bin/ipcalc.sh "$hotspot_ip/$hotspot_cidr" 2>/dev/null)" || fail_json 'network' 'Invalid hotspot IP/CIDR'
	network_addr="$(printf '%s' "$calc_output" | awk -F= '$1 == "NETWORK" {print $2}')"
	netmask="$(printf '%s' "$calc_output" | awk -F= '$1 == "NETMASK" {print $2}')"

	dhcp_start="$(last_octet "$pool_start")"
	dhcp_end="$(last_octet "$pool_end")"
	case "$dhcp_start$dhcp_end" in *[!0-9]*|'') fail_json 'dhcp' 'DHCP pool must be IPv4 addresses in the hotspot subnet' ;; esac
	dhcp_limit=$((dhcp_end - dhcp_start + 1))
	[ "$dhcp_limit" -gt 0 ] || fail_json 'dhcp' 'DHCP pool end must be greater than pool start'
	[ "$(network_for "$pool_start" "$hotspot_cidr")" = "$network_addr" ] || fail_json 'dhcp' 'DHCP pool start must be inside the hotspot subnet'
	[ "$(network_for "$pool_end" "$hotspot_cidr")" = "$network_addr" ] || fail_json 'dhcp' 'DHCP pool end must be inside the hotspot subnet'

	if [ "$dual_quick_mode" = '1' ]; then
		secondary_calc_output="$(/bin/ipcalc.sh "$secondary_hotspot_ip/$secondary_hotspot_cidr" 2>/dev/null)" || fail_json 'quick' 'Secondary hotspot IP/CIDR is invalid'
		secondary_network_addr="$(printf '%s' "$secondary_calc_output" | awk -F= '$1 == "NETWORK" {print $2}')"
		secondary_netmask="$(printf '%s' "$secondary_calc_output" | awk -F= '$1 == "NETMASK" {print $2}')"

		secondary_dhcp_start="$(last_octet "$secondary_pool_start")"
		secondary_dhcp_end="$(last_octet "$secondary_pool_end")"
		case "$secondary_dhcp_start$secondary_dhcp_end" in *[!0-9]*|'') fail_json 'quick' 'Secondary DHCP pool must be IPv4 addresses in the secondary subnet' ;; esac
		secondary_dhcp_limit=$((secondary_dhcp_end - secondary_dhcp_start + 1))
		[ "$secondary_dhcp_limit" -gt 0 ] || fail_json 'quick' 'Secondary DHCP pool end must be greater than pool start'
		[ "$(network_for "$secondary_pool_start" "$secondary_hotspot_cidr")" = "$secondary_network_addr" ] || fail_json 'quick' 'Secondary DHCP pool start must be inside the secondary subnet'
		[ "$(network_for "$secondary_pool_end" "$secondary_hotspot_cidr")" = "$secondary_network_addr" ] || fail_json 'quick' 'Secondary DHCP pool end must be inside the secondary subnet'
		[ "$secondary_network_addr" != "$network_addr" ] || fail_json 'quick' 'Primary and secondary hotspot networks must be different'
	fi

	device_section="${subscriber_interface}_dev"
	device_name="br-$subscriber_interface"
	[ "$subscriber_interface" = 'hotspot' ] && device_name='br-hotspot'

	if [ "$dual_quick_mode" = '1' ]; then
		secondary_device_section="${secondary_subscriber_interface}_dev"
		secondary_device_name="br-$secondary_subscriber_interface"
		[ "$secondary_subscriber_interface" = 'hotspot' ] && secondary_device_name='br-hotspot'
	fi

	wan_zone="$(zone_for_network "$wan_interface")"
	uam_page="$portal_path/login.html"
	[ "$terms_enabled" = '1' ] && uam_page="$portal_path/terms.html"
	[ "$mikrotik_compat" = '1' ] && uam_page="/cgi-bin/mikrotik-gate"
	runtime_mode='chilli'
	if [ ! -x /etc/init.d/chilli ] || ! modprobe tun >/dev/null 2>&1; then
		runtime_mode='dnsmasq'
	fi

	primary_bandwidth_up="$bandwidth_up"
	primary_bandwidth_down="$bandwidth_down"
	primary_shared_users="$shared_users"
	secondary_bandwidth_up='0'
	secondary_bandwidth_down='0'
	secondary_shared_users="$shared_users"

	if [ "$dual_quick_mode" = '1' ]; then
		primary_limits="$(quick_policy_limits "$quick_policy_primary" "$bandwidth_up" "$bandwidth_down" "$shared_users")"
		primary_bandwidth_up="$(printf '%s' "$primary_limits" | cut -d';' -f1)"
