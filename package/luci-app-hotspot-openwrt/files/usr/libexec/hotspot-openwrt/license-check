#!/bin/sh
# Alemprator Guard - License Check Wrapper
# This script calls the compiled guard binary.
# Even if someone reads this script, they cannot bypass the
# server-side validation without the embedded HMAC key.

GUARD_BIN="/usr/libexec/hotspot-openwrt/alemprator-guard"
VALIDATE_BIN="/usr/libexec/hotspot-openwrt/validate"

if [ -x "$GUARD_BIN" ]; then
    exec "$GUARD_BIN"
fi

# Fallback: use the validate helper when guard binary is unavailable.
if [ -x "$VALIDATE_BIN" ]; then
    "$VALIDATE_BIN" >/dev/null 2>&1
    exit $?
fi

# Last-resort compatibility mode.
logger -t alemprator-guard "Guard binary and validate helper are missing; allowing temporarily"
exit 0
