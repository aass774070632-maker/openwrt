#!/bin/sh
# logs — Return recent Hotspot/Chilli/RADIUS log lines as JSON
# Usage: logs [lines]

LINES="${1:-100}"
LINES="$(printf '%s' "$LINES" | awk '{ v=$1+0; if(v<1)v=1; if(v>500)v=500; print v }')"

json_escape() {
	# Use awk for robust JSON escaping (including control characters)
	printf '%s' "$1" | awk '
	BEGIN {
	    for (i = 0; i < 32; i++) {
	        c = sprintf("%c", i)
	        esc[c] = sprintf("\\u%04x", i)
	    }
	    esc["\\"] = "\\\\"
	    esc["\""] = "\\\""
	    esc["\t"] = "\\t"
	    esc["\r"] = "\\r"
	    esc["\n"] = "\\n"
	}
	{
	    out = ""
	    for (i = 1; i <= length($0); i++) {
	        c = substr($0, i, 1)
	        if (c in esc) out = out esc[c]
	        else out = out c
	    }
	    printf "%s", out
	}'
}

entries=''
count=0

while IFS= read -r line; do
	escaped="$(json_escape "$line")"
	[ -z "$escaped" ] && continue
	if [ -n "$entries" ]; then
		entries="$entries,"
	fi
	entries="${entries}\"$escaped\""
	count=$((count + 1))
done <<EOF
$(logread 2>/dev/null | grep -E -i 'chilli|coova|radius|hotspot|tun0|uam' | tail -n "$LINES")
EOF

printf '{"ok":true,"count":%d,"lines":[%s]}\n' "$count" "$entries"
