#!/bin/sh /etc/rc.common

START=91
USE_PROCD=1

start_service() {
	# Always run apply at boot so the WAN/PPPoE uplink is configured even
	# when the hotspot is disabled. The apply script applies WAN
	# independently of the hotspot and only starts hotspot services
	# (chilli/radius-proxy) when the hotspot is actually enabled.
	/usr/libexec/hotspot-openwrt/apply --start > /tmp/hotspot-apply-boot.log 2>&1

	[ "$(uci -q get hotspot_openwrt.main.enabled)" = '1' ] || return 0

	# Start presence-watchdog via procd
	if [ -x /usr/libexec/hotspot-openwrt/presence-watchdog ]; then
		procd_open_instance
		procd_set_param command /usr/libexec/hotspot-openwrt/presence-watchdog
		procd_set_param respawn
		procd_close_instance
	fi

	# Start mac-cookie-watchdog via procd
	if [ -x /usr/libexec/hotspot-openwrt/mac-cookie-watchdog ]; then
		procd_open_instance
		procd_set_param command /usr/libexec/hotspot-openwrt/mac-cookie-watchdog
		procd_set_param respawn
		procd_close_instance
	fi

	# Start maint-watchdog via procd (only if explicitly enabled)
	if [ "$(uci -q get hotspot_openwrt.main.maint_enabled)" = '1' ] && [ -x /usr/libexec/hotspot-openwrt/maint-watchdog ]; then
		procd_open_instance
		procd_set_param command /usr/libexec/hotspot-openwrt/maint-watchdog
		procd_set_param respawn
		procd_close_instance
	fi

	# Run enforcement-check on startup
	if [ -x /usr/libexec/hotspot-openwrt/enforcement-check ]; then
		/usr/libexec/hotspot-openwrt/enforcement-check > /dev/null 2>&1 &
	fi
}

stop_service() {
	/etc/init.d/chilli stop > /dev/null 2>&1 || true

	# Clean up dnsmasq hotspot config
	rm -f /etc/dnsmasq.d/hotspot-openwrt.conf
	/etc/init.d/dnsmasq reload > /dev/null 2>&1 || true

	# Remove nftables hotspot sets if they exist
	nft flush set inet fw4 hotspot_blocked_mac 2>/dev/null || true
	nft flush set inet fw4 hotspot_bypass_mac 2>/dev/null || true
	nft delete set inet fw4 hotspot_blocked_mac 2>/dev/null || true
	nft delete set inet fw4 hotspot_bypass_mac 2>/dev/null || true

	# Restore /etc/hosts (remove hotspot domain line)
	local domain
	domain="$(uci -q get hotspot_openwrt.main.domain)"
	[ -n "$domain" ] && sed -i "/[[:space:]]$domain$/d" /etc/hosts 2>/dev/null || true

	# Remove state files
	rm -f /var/run/hotspot-openwrt-absent/* 2>/dev/null || true
	rmdir /var/run/hotspot-openwrt-absent 2>/dev/null || true
}

service_triggers() {
	procd_add_reload_trigger "hotspot_openwrt"
}
