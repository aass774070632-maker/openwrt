#!/bin/sh

# Alemprator Guard - Persistent Firewall Rules
# Ensures the hotspot_allowed set exists after reboot or reset

# 1. Create the persistent script
mkdir -p /etc/hotspot-openwrt

cat > /etc/hotspot-openwrt/firewall.sh <<'EOF'
#!/bin/sh
# This script is called by fw4 to inject custom NFT rules

# Create the set if it doesn't exist
nft "add set inet fw4 hotspot_allowed { type ipv4_addr; flags timeout; }" 2>/dev/null

# Create and clear the auth chain
nft "add chain inet fw4 hotspot_auth" 2>/dev/null
nft "flush chain inet fw4 hotspot_auth" 2>/dev/null

# Add rules to the auth chain
nft "add rule inet fw4 hotspot_auth ip saddr @hotspot_allowed counter accept" 2>/dev/null
nft "add rule inet fw4 hotspot_auth ip saddr 20.20.20.0/24 counter reject" 2>/dev/null

# Jump to our auth chain from forward
nft "delete rule inet fw4 forward ip saddr 20.20.20.0/24 jump hotspot_auth" 2>/dev/null
nft "insert rule inet fw4 forward ip saddr 20.20.20.0/24 jump hotspot_auth" 2>/dev/null
EOF

chmod +x /etc/hotspot-openwrt/firewall.sh

# 2. Integrate with OpenWrt Firewall (fw4)
if ! grep -q "/etc/hotspot-openwrt/firewall.sh" /etc/config/firewall; then
    SECTION=$(uci add firewall include)
    uci set firewall.$SECTION.enabled='1'
    uci set firewall.$SECTION.path='/etc/hotspot-openwrt/firewall.sh'
    uci commit firewall
fi

# 3. DNS Redirects for Captive Portal Detection
# This forces phones to show the login notification
uci -q batch <<EOF
add_list dhcp.@dnsmasq[0].address='/connectivitycheck.gstatic.com/20.20.20.1'
add_list dhcp.@dnsmasq[0].address='/connectivitycheck.android.com/20.20.20.1'
add_list dhcp.@dnsmasq[0].address='/clients3.google.com/20.20.20.1'
add_list dhcp.@dnsmasq[0].address='/msftconnecttest.com/20.20.20.1'
add_list dhcp.@dnsmasq[0].address='/msftncsi.com/20.20.20.1'
add_list dhcp.@dnsmasq[0].address='/apple.com/20.20.20.1'
add_list dhcp.@dnsmasq[0].address='/b.net/20.20.20.1'
commit dhcp
EOF

/etc/init.d/dnsmasq restart

# 4. Uhttpd Config for Captive Portal (Error Page)
# This handles the magic redirection for generate_204
uci -q batch <<EOF
set uhttpd.main.error_page='/cgi-bin/generate_204'
commit uhttpd
EOF

/etc/init.d/uhttpd restart

# 5. Apply now
/etc/init.d/firewall restart

exit 0
