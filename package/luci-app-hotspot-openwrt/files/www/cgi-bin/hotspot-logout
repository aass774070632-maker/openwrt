#!/bin/sh

# Hotspot Alemprator Guard - Hybrid Logout Handler

json_escape() {
	printf '%s' "$1" | awk '{ gsub(/\\/, "\\\\"); gsub(/"/, "\\\""); printf "%s%s", (NR>1 ? "\\n" : ""), $0 }'
}

query_value() {
	printf '%s' "&$QUERY_STRING" | sed -n "s/.*[&?]$1=\([^&]*\).*/\1/p" | head -n 1 | sed 's/+/ /g; s/%40/@/g; s/%2[Bb]/+/g; s/%2[Dd]/-/g; s/%2[Ee]/./g; s/%2[Ff]/\//g; s/%3[Aa]/:/g; s/%3[Ff]/?/g; s/%3[Dd]/=/g; s/%26/\&/g; s/%5[Ff]/_/g'
}

# --- Error Messages ---
MSG_SUCCESS='تم تسجيل الخروج بنجاح.'
MSG_FAIL='فشل تسجيل الخروج.'
MSG_CHILLI_FAIL='تعذر قطع جلسة الإنترنت من Chilli.'

remote_addr="${REMOTE_ADDR:-}"
format="$(query_value format)"
username="$(query_value username)"
logout_ok='false'
message="$MSG_FAIL"
err_code='FAIL'
matched_socket=''
before_state=''
after_state=''
client_mac=''
chilli_out="$(mktemp)"
trap 'rm -f "$chilli_out"' EXIT
# (... existing client_field function ...)

if [ -n "$remote_addr" ]; then
    # 1. Try Chilli Logout
    if command -v chilli_query >/dev/null 2>&1; then
        for socket_path in /var/run/chilli_hotspot_openwrt.sock /var/run/chilli_hotspot_openwrt_secondary.sock; do
            [ -S "$socket_path" ] || continue
            state="$(client_field "$socket_path" 3)"
            mac="$(client_field "$socket_path" 1)"
            [ -n "$state$mac" ] || continue
            [ -n "$before_state" ] || before_state="$state"
            matched_socket="$socket_path"
            chilli_query -s "$socket_path" logout ip "$remote_addr" >"$chilli_out" 2>&1 || true
            if [ -n "$mac" ]; then
                [ -x /usr/libexec/hotspot-openwrt/mac-cookies ] && /usr/libexec/hotspot-openwrt/mac-cookies delete "$mac" >/dev/null 2>&1 || true
                chilli_query -s "$socket_path" logout mac "$mac" >"$chilli_out" 2>&1 || true
                client_mac="$mac"
            fi
            after_state="$(client_field "$socket_path" 3)"
            [ "$after_state" != 'pass' ] && logout_ok='true'
        done
    fi

    # 2. Emergency Mode Logout
    # Clear conntrack entries to terminate session
    command -v conntrack >/dev/null 2>&1 && conntrack -D -s "$remote_addr" >/dev/null 2>&1 || true
    command -v conntrack >/dev/null 2>&1 && conntrack -D -d "$remote_addr" >/dev/null 2>&1 || true

    [ -n "$matched_socket" ] || logout_ok='true'
    if [ "$logout_ok" = 'true' ]; then
        message="$MSG_SUCCESS"
        err_code='SUCCESS'
    else
        message="$MSG_CHILLI_FAIL"
        err_code='CHILLI_FAIL'
    fi
fi

if [ "$format" = 'json' ]; then
	printf 'Content-Type: application/json\r\n'
	printf 'Cache-Control: no-store\r\n\r\n'
    printf '{"ok":%s,"message":"%s","err_code":"%s","state_before":"%s","state_after":"%s","mac":"%s"}\n' "$logout_ok" "$(json_escape "$message")" "$(json_escape "$err_code")" "$(json_escape "$before_state")" "$(json_escape "$after_state")" "$(json_escape "$client_mac")"
	exit 0
fi

printf 'Status: 302 Found\r\n'
printf 'Location: /hotspot/login.html?t=%s\r\n' "$(date +%s)"
printf 'Cache-Control: no-store\r\n\r\n'