#!/bin/sh

# Hotspot Alemprator Guard - Hybrid Logout Handler

json_escape() {
	printf '%s' "$1" | awk '{ gsub(/\\/, "\\\\"); gsub(/"/, "\\\""); printf "%s%s", (NR>1 ? "\\n" : ""), $0 }'
}

query_value() {
	printf '%s' "&$QUERY_STRING" | sed -n "s/.*[&?]$1=\([^&]*\).*/\1/p" | head -n 1 | sed 's/+/ /g; s/%40/@/g; s/%2[Bb]/+/g; s/%2[Dd]/-/g; s/%2[Ee]/./g; s/%2[Ff]/\//g; s/%3[Aa]/:/g; s/%3[Ff]/?/g; s/%3[Dd]/=/g; s/%26/\&/g; s/%5[Ff]/_/g'
}

remote_addr="${REMOTE_ADDR:-}"
format="$(query_value format)"
logout_ok='false'
message='فشل تسجيل الخروج.'

if [ -n "$remote_addr" ]; then
    # 1. Try Chilli Logout
    socket_path='/var/run/chilli_hotspot_openwrt.sock'
    if [ -S "$socket_path" ] && command -v chilli_query >/dev/null 2>&1; then
        chilli_query -s "$socket_path" logout ip "$remote_addr" >/dev/null 2>&1
    fi

    # 2. Emergency Mode (NFT Set) Logout
    # Remove from allowed set and srcnat
    nft delete element inet fw4 hotspot_allowed { "$remote_addr" } 2>/dev/null
    
    logout_ok='true'
    message='تم تسجيل الخروج بنجاح.'
fi

if [ "$format" = 'json' ]; then
	printf 'Content-Type: application/json\r\n'
	printf 'Cache-Control: no-store\r\n\r\n'
	printf '{"ok":%s,"message":"%s"}\n' "$logout_ok" "$(json_escape "$message")"
	exit 0
fi

printf 'Status: 302 Found\r\n'
printf 'Location: /hotspot/login.html?t=%s\r\n' "$(date +%s)"
printf 'Cache-Control: no-store\r\n\r\n'