#!/bin/sh

# Hotspot Alemprator Guard - Hybrid Login Handler
# Supports Chilli Mode and Direct MikroTik (Emergency) Mode

json_escape() {
	printf '%s' "$1" | awk '{ gsub(/\\/, "\\\\"); gsub(/"/, "\\\""); printf "%s%s", (NR>1 ? "\\n" : ""), $0 }'
}

query_value() {
	printf '%s' "&$QUERY_STRING" | sed -n "s/.*[&?]$1=\([^&]*\).*/\1/p" | head -n 1 | sed 's/+/ /g; s/%40/@/g; s/%2[Bb]/+/g; s/%2[Dd]/-/g; s/%2[Ee]/./g; s/%2[Ff]/\//g; s/%3[Aa]/:/g; s/%3[Ff]/?/g; s/%3[Dd]/=/g; s/%26/\&/g; s/%5[Ff]/_/g'
}

# --- Settings ---
socket_path='/var/run/chilli_hotspot_openwrt.sock'
remote_addr="${REMOTE_ADDR:-}"
username="$(query_value username)"
password="$(query_value password)"
card_number="$username"
login_ok='false'
message='فشل تسجيل الدخول.'

# MikroTik Config from UCI
mt_host="$(uci -q get hotspot_openwrt.main.radius_server)"
mt_user="$(uci -q get hotspot_openwrt.main.userman_rest_username)"
mt_pass="$(uci -q get hotspot_openwrt.main.userman_rest_password)"

# --- Main Logic ---

if [ -z "$remote_addr" ]; then
    message='لم يتم تحديد عنوان جهاز العميل.'
elif [ -z "$username" ]; then
    message='أدخل رقم الكرت أولاً.'
else
    # 1. Try Chilli Mode First
    if [ -S "$socket_path" ] && command -v chilli_query >/dev/null 2>&1; then
        chilli_query -s "$socket_path" login ip "$remote_addr" username "$username" password "$password" >/tmp/h-login.$$ 2>&1
        state="$(chilli_query -s "$socket_path" list 2>/dev/null | awk -v ip="$remote_addr" '$2 == ip { print $3 }')"
        if [ "$state" = "pass" ]; then
            login_ok='true'
            message='تم تسجيل الدخول بنجاح (Chilli).'
            
            # Save MAC Cookie globally for all models
            if [ -x /usr/libexec/hotspot-openwrt/mac-cookies ]; then
                mac="$(chilli_query -s "$socket_path" list 2>/dev/null | awk -v ip="$remote_addr" '$2 == ip { print $1 }')"
                /usr/libexec/hotspot-openwrt/mac-cookies save "$mac" "$remote_addr" "$username" >/dev/null 2>&1 || true
            fi
        fi
        rm -f /tmp/h-login.$$
    fi

    # 2. Emergency Mode (Direct MikroTik Auth)
    if [ "$login_ok" = "false" ]; then
        # Check card with MikroTik API
        # Construct Basic Auth
        AUTH_B64=$(printf "%s:%s" "$mt_user" "$mt_pass" | openssl base64 | tr -d '\n')
        
        # Check if user exists and is active in User Manager
        # We use uclient-fetch since curl is missing
        RESP=$(uclient-fetch -q -O - --header "Authorization: Basic $AUTH_B64" "http://$mt_host/rest/user-manager/user?name=$username" 2>/dev/null)
        
        if echo "$RESP" | grep -q "\"name\":\"$username\""; then
            # Success! Auth accepted by MikroTik
            login_ok='true'
            
            # Open Firewall for this IP using NFT Set
            nft add element inet fw4 hotspot_allowed { "$remote_addr" } 2>/dev/null
            nft add rule inet fw4 srcnat ip saddr @hotspot_allowed counter masquerade 2>/dev/null
            
            # Save MAC Cookie globally for all models
            if [ -x /usr/libexec/hotspot-openwrt/mac-cookies ]; then
                # In emergency mode without Chilli, MAC is harder to get via arp, so we try our best
                mac="$(ip neigh show "$remote_addr" 2>/dev/null | awk '{print $5}')"
                [ -n "$mac" ] && /usr/libexec/hotspot-openwrt/mac-cookies save "$mac" "$remote_addr" "$username" >/dev/null 2>&1 || true
            fi
            
            message='تم تسجيل الدخول بنجاح. تم فتح الإنترنت لجهازك.'
        else
            message="رقم الكرت غير صحيح أو منتهي الصلاحية في MikroTik User Manager."
        fi
    fi
fi

# --- Response ---
printf 'Content-Type: application/json\r\n'
printf 'Cache-Control: no-store\r\n\r\n'
printf '{"ok":%s,"message":"%s","username":"%s"}\n' "$login_ok" "$(json_escape "$message")" "$(json_escape "$username")"