{
	"luci-app-setup": {
		"description": "Grant UCI and status access for luci-app-setup",
		"read": {
			"cgi-io": [ "backup", "download" ],
			"file": {
				"/usr/libexec/hotspot-openwrt/status-json": [ "exec" ]
			},
			"uci": [ "alemprator_firstboot", "alemprator_ota", "chilli", "hotspot_openwrt", "network", "setup", "watchcat", "wireless" ],
			"ubus": {
				"system": [ "board" ],
				"network.interface.lan": [ "status" ],
				"network.wireless": [ "status" ]
			}
		},
		"write": {
			"cgi-io": [ "upload" ],
			"file": {
				"/bin/tar -tzf /tmp/backup.tar.gz": [ "exec" ],
				"/usr/libexec/hotspot-openwrt/apply": [ "exec" ],
				"/sbin/reboot": [ "exec" ],
				"/sbin/sysupgrade --restore-backup /tmp/backup.tar.gz": [ "exec" ],
				"/tmp/backup.tar.gz": [ "write" ]
			},
			"uci": [ "alemprator_firstboot", "alemprator_ota", "chilli", "dhcp", "firewall", "hotspot_openwrt", "network", "setup", "watchcat", "wireless" ],
			"ubus": {
				"file": [ "exec", "remove", "write" ],
				"luci": [ "setPassword" ]
			}
		}
	}
}
